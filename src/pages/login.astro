---
import BaseLayout from '../layouts/BaseLayout.astro';
import '../styles/global.css';
---
<BaseLayout title="Login — Pengumuman Kelulusan">
  <div class="min-h-screen flex w-full font-sans overflow-hidden bg-slate-50 dark:bg-[#0f0f1a] transition-colors duration-300">
    
    <!-- ── LEFT: BRANDING & VISUALS (Desktop Only) ── -->
    <div class="hidden lg:flex flex-1 relative items-center justify-center p-12">
      <!-- Animated Background Blobs -->
      <div class="absolute inset-0 z-0 overflow-hidden">
        <div class="absolute top-[20%] left-[10%] w-[30rem] h-[30rem] bg-indigo-600/10 dark:bg-indigo-600/20 rounded-full mix-blend-screen filter blur-[100px] animate-pulse-slow"></div>
        <div class="absolute bottom-[20%] right-[10%] w-[35rem] h-[35rem] bg-purple-600/10 dark:bg-purple-600/20 rounded-full mix-blend-screen filter blur-[100px] animate-pulse-slow" style="animation-delay:-2s;"></div>
      </div>
      
      <!-- Content -->
      <div class="relative z-10 max-w-lg float-anim">
        <div class="inline-flex items-center justify-center w-20 h-20 rounded-[2rem] mb-8 shadow-xl dark:shadow-2xl bg-white/40 dark:bg-white/5 border border-white/60 dark:border-white/10 backdrop-blur-xl">
          <svg class="w-10 h-10 text-indigo-500 dark:text-indigo-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 14l9-5-9-5-9 5 9 5z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 14l6.16-3.422a12.083 12.083 0 01.665 6.479A11.952 11.952 0 0012 20.055a11.952 11.952 0 00-6.824-2.998 12.078 12.078 0 01.665-6.479L12 14z"/></svg>
        </div>
        <h1 class="text-5xl font-black text-transparent bg-clip-text bg-gradient-to-br from-slate-900 to-slate-600 dark:from-white dark:to-slate-400 mb-6 leading-tight tracking-tight">
          Portal Informasi<br/>Kelulusan Terpadu
        </h1>
        <p class="text-lg text-slate-600 dark:text-slate-400 leading-relaxed font-light mb-12">
          Platform digital terpusat untuk memantau status kelulusan, mencetak SKL, dan mengakses data akademik dengan aman dan responsif.
        </p>

        <!-- Dynamic aesthetic elements -->
        <div class="flex gap-4 items-center">
          <div class="flex -space-x-3">
            <div class="w-10 h-10 rounded-full bg-indigo-50 dark:bg-indigo-500/20 border border-indigo-200 dark:border-indigo-500/50 flex items-center justify-center backdrop-blur-sm"><svg class="w-5 h-5 text-indigo-500 dark:text-indigo-300" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"/></svg></div>
            <div class="w-10 h-10 rounded-full bg-purple-50 dark:bg-purple-500/20 border border-purple-200 dark:border-purple-500/50 flex items-center justify-center backdrop-blur-sm"><svg class="w-5 h-5 text-purple-500 dark:text-purple-300" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"/></svg></div>
            <div class="w-10 h-10 rounded-full bg-emerald-50 dark:bg-emerald-500/20 border border-emerald-200 dark:border-emerald-500/50 flex items-center justify-center backdrop-blur-sm"><svg class="w-5 h-5 text-emerald-500 dark:text-emerald-300" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/></svg></div>
          </div>
          <span class="text-sm font-medium text-slate-500">Aman & Terenkripsi</span>
        </div>
      </div>
    </div>

    <!-- ── RIGHT: LOGIN FORM ── -->
    <div class="flex-1 flex items-center justify-center p-6 sm:p-12 relative z-10 bg-white dark:bg-[#131320] lg:border-l lg:border-slate-200 lg:dark:border-white/5 lg:shadow-[-20px_0_50px_rgba(0,0,0,0.05)] lg:dark:shadow-[-20px_0_50px_rgba(0,0,0,0.5)] transition-colors duration-300">
      
      <!-- Mobile Background Fallback -->
      <div class="absolute inset-0 lg:hidden z-0 overflow-hidden pointer-events-none">
        <div class="absolute top-[10%] left-[0%] w-72 h-72 bg-indigo-600/10 dark:bg-indigo-600/20 rounded-full mix-blend-screen filter blur-[80px] animate-pulse-slow"></div>
        <div class="absolute bottom-[10%] right-[0%] w-72 h-72 bg-purple-600/10 dark:bg-purple-600/20 rounded-full mix-blend-screen filter blur-[80px] animate-pulse-slow" style="animation-delay:-2s;"></div>
      </div>

      <div class="w-full max-w-md relative z-10 bounce-in">
        
        <!-- Mobile Logo -->
        <div class="lg:hidden text-center mb-8">
          <div class="inline-flex items-center justify-center w-16 h-16 rounded-2xl mb-4" style="background:linear-gradient(135deg,#6366f1,#4338ca);">
            <svg class="w-8 h-8 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/></svg>
          </div>
          <h1 class="text-2xl font-black text-slate-900 dark:text-white mb-1 tracking-tight">Portal Kelulusan</h1>
        </div>

        <div class="mb-10 hidden lg:block">
          <h2 class="text-3xl font-black text-slate-900 dark:text-white mb-2 tracking-tight transition-colors">Selamat Datang 👋</h2>
          <p class="text-slate-500 dark:text-slate-400 text-sm transition-colors">Silahkan pilih role dan masuk ke akun Anda.</p>
        </div>

        <!-- Glass Container for Form -->
        <div class="glass-card p-8 md:p-10 !bg-slate-50/60 dark:!bg-[#1a1a2e]/60 !border-slate-200 dark:!border-white/5 shadow-xl transition-colors duration-300">
          
          <!-- Role Tabs (Segmented Control style) -->
          <div class="relative flex p-1 mb-8 bg-slate-200/50 dark:bg-[#0f0f1a] rounded-xl border border-slate-300/50 dark:border-white/5 shadow-inner transition-colors duration-300">
            <button id="tab-admin" onclick="setRole('admin')" class="role-tab flex-1 py-2.5 rounded-lg text-sm font-semibold transition-all duration-300 z-10 text-white">Admin</button>
            <button id="tab-guru" onclick="setRole('guru')" class="role-tab flex-1 py-2.5 rounded-lg text-sm font-semibold transition-all duration-300 z-10 text-slate-500 hover:text-slate-700 dark:hover:text-slate-300">Guru</button>
            <button id="tab-siswa" onclick="setRole('siswa')" class="role-tab flex-1 py-2.5 rounded-lg text-sm font-semibold transition-all duration-300 z-10 text-slate-500 hover:text-slate-700 dark:hover:text-slate-300">Siswa</button>
            
            <!-- Sliding Indicator -->
            <div id="tab-indicator" class="absolute top-1 bottom-1 w-[33%] rounded-lg transition-all duration-300 shadow-lg" style="background:linear-gradient(135deg,#6366f1,#4f46e5); left:0.25rem;"></div>
          </div>

          <!-- Role Hint -->
          <div id="role-hint" class="mb-6 p-4 rounded-xl text-xs text-slate-600 dark:text-slate-400 border border-indigo-500/20 bg-indigo-500/5 transition-all duration-300 opacity-100">
            <div class="flex gap-3">
              <svg class="w-4 h-4 text-indigo-500 dark:text-indigo-400 shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
              <p id="hint-text" class="leading-relaxed">Login sebagai Admin: username <code class="text-indigo-600 dark:text-indigo-400 font-bold">admin</code>, password <code class="text-indigo-600 dark:text-indigo-400 font-bold">Admin@123</code></p>
            </div>
          </div>

          <!-- Form -->
          <form id="login-form" class="space-y-5" novalidate>
            <div class="group">
              <label class="block text-xs font-semibold text-slate-500 dark:text-slate-400 uppercase tracking-wider mb-2 group-focus-within:text-indigo-600 dark:group-focus-within:text-indigo-400 transition-colors">Username / NISN</label>
              <div class="relative">
                <div class="absolute inset-y-0 left-0 pl-4 flex items-center pointer-events-none">
                  <svg class="w-5 h-5 text-slate-400 dark:text-slate-500 group-focus-within:text-indigo-500 transition-colors" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/></svg>
                </div>
                <input type="text" id="username" required autocomplete="off"
                  class="w-full pl-11 pr-5 py-3.5 rounded-xl text-slate-900 dark:text-white placeholder-slate-400 dark:placeholder-slate-600 outline-none text-sm font-medium tracking-wide transition-all bg-white dark:bg-[#0f0f1a] border border-slate-300 dark:border-white/5 focus:border-indigo-500 focus:ring-1 focus:ring-indigo-500" 
                  placeholder="Masukkan username..." />
              </div>
            </div>
            
            <div class="group">
              <label class="block text-xs font-semibold text-slate-500 dark:text-slate-400 uppercase tracking-wider mb-2 group-focus-within:text-indigo-600 dark:group-focus-within:text-indigo-400 transition-colors">Password</label>
              <div class="relative">
                <div class="absolute inset-y-0 left-0 pl-4 flex items-center pointer-events-none">
                  <svg class="w-5 h-5 text-slate-400 dark:text-slate-500 group-focus-within:text-indigo-500 transition-colors" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"/></svg>
                </div>
                <input type="password" id="password" required
                  class="w-full pl-11 pr-12 py-3.5 rounded-xl text-slate-900 dark:text-white placeholder-slate-400 dark:placeholder-slate-600 outline-none text-sm font-medium tracking-widest transition-all bg-white dark:bg-[#0f0f1a] border border-slate-300 dark:border-white/5 focus:border-indigo-500 focus:ring-1 focus:ring-indigo-500" 
                  placeholder="••••••••" />
                <button type="button" id="toggle-pw" class="absolute right-4 top-1/2 -translate-y-1/2 text-slate-400 dark:text-slate-500 hover:text-slate-600 dark:hover:text-slate-300 transition-colors focus:outline-none">
                  <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"/></svg>
                </button>
              </div>
            </div>

            <button type="submit" id="btn-login" class="btn-primary w-full mt-6 py-4 rounded-xl font-bold tracking-wide text-[15px] group flex items-center justify-center overflow-hidden relative shadow-md shadow-indigo-500/20">
              <span class="absolute inset-0 w-full h-full bg-gradient-to-r from-indigo-500 via-purple-500 to-indigo-500 opacity-0 group-hover:opacity-100 transition-opacity duration-500 bg-[length:200%_auto] animate-shimmer"></span>
              <span class="relative z-10 flex items-center gap-2">
                Masuk ke Sistem
                <svg class="w-5 h-5 group-hover:translate-x-1 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3"/></svg>
              </span>
            </button>
          </form>

        </div>

        <div class="mt-8 text-center">
          <a href="/" class="inline-flex items-center gap-2 text-sm text-slate-500 hover:text-indigo-600 dark:hover:text-indigo-400 transition-colors font-medium group">
            <svg class="w-4 h-4 group-hover:-translate-x-1 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"/></svg>
            Kembali ke Halaman Depan
          </a>
        </div>

      </div>
    </div>
  </div>

  <style>
    /* Custom animate for sliding indicator */
    @keyframes shimmer { 0% { background-position: 0% 50%; } 100% { background-position: 200% 50%; } }
    .animate-shimmer { animation: shimmer 3s linear infinite; }
    
    @keyframes bounce-in { 0% { transform: scale(0.9); opacity:0; } 100% { transform: scale(1); opacity:1; } }
    .animate-bounce-in { animation: bounce-in 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.275) forwards; }
  </style>

  <script is:inline>
  async function sha256(msg) {
    const buf = await crypto.subtle.digest('SHA-256', new TextEncoder().encode(msg));
    return Array.from(new Uint8Array(buf)).map(b => b.toString(16).padStart(2,'0')).join('');
  }

  const HINTS = {
    admin: 'Login sebagai Admin: username <code class="text-indigo-600 dark:text-indigo-400 font-bold">admin</code>, password <code class="text-indigo-600 dark:text-indigo-400 font-bold">Admin@123</code>',
    guru:  'Login sebagai Guru: username <code class="text-indigo-600 dark:text-indigo-400 font-bold">guru.ipa</code>, password <code class="text-indigo-600 dark:text-indigo-400 font-bold">Guru@123</code>',
    siswa: 'Login sebagai Siswa: masukkan <code class="text-indigo-600 dark:text-indigo-400 font-bold">NISN</code> sebagai username & password.',
  };

  let currentRole = 'admin';
  function setRole(role) {
    currentRole = role;
    
    // Update tabs text color
    ['admin','guru','siswa'].forEach((r, idx) => {
      const t = document.getElementById('tab-' + r);
      if (r === role) {
        t.classList.add('text-white');
        t.classList.remove('text-slate-500', 'hover:text-slate-700', 'dark:hover:text-slate-300');
      } else {
        t.classList.remove('text-white');
        t.classList.add('text-slate-500', 'hover:text-slate-700', 'dark:hover:text-slate-300');
      }
    });

    // Move Indicator
    const indicator = document.getElementById('tab-indicator');
    const positions = { admin: '0.25rem', guru: '33.33%', siswa: '66.66%' };
    indicator.style.transform = `translateX(${role === 'admin' ? '0' : role === 'guru' ? '100%' : '200%'})`;
    indicator.style.left = role === 'admin' ? '0.25rem' : role === 'guru' ? '0' : '-0.25rem';

    // Update hints with slight animation
    const hintDiv = document.getElementById('role-hint');
    hintDiv.style.opacity = '0';
    setTimeout(() => {
      document.getElementById('hint-text').innerHTML = HINTS[role];
      document.getElementById('username').placeholder = role === 'siswa' ? 'Masukkan NISN...' : 'Masukkan username...';
      hintDiv.style.opacity = '1';
    }, 200);
  }

  // Toggle password visibility
  document.getElementById('toggle-pw').addEventListener('click', () => {
    const pw = document.getElementById('password');
    pw.type = pw.type === 'password' ? 'text' : 'password';
  });

  // Show error visually
  function showError(msg) {
    showToast(msg, 'error');
  }

  // Login Submit
  document.addEventListener('DOMContentLoaded', async () => {
    let usersData = null;
    try {
      const r = await fetch('/users.json', { cache: 'no-store' });
      usersData = await r.json();
    } catch {
      showError('Gagal memuat data sistem.');
    }

    document.getElementById('login-form').addEventListener('submit', async e => {
      e.preventDefault();
      const username = document.getElementById('username').value.trim();
      const password = document.getElementById('password').value;

      if (!username) { 
        showToast(currentRole === 'siswa' ? 'NISN tidak boleh kosong.' : 'Username tidak boleh kosong.', 'warning'); 
        return; 
      }
      if (!password) { 
        showToast('Password tidak boleh kosong.', 'warning'); 
        return; 
      }
      
      const btn      = document.getElementById('btn-login');

      if (!usersData) { showError('Data sistem belum siap.'); return; }

      // Security: Anti Brute Force
      const lockoutKey = 'auth_lockout_' + username;
      const attemptsKey = 'auth_attempts_' + username;
      const lockoutTime = localStorage.getItem(lockoutKey);
      if (lockoutTime && Date.now() < parseInt(lockoutTime)) {
        const wait = Math.ceil((parseInt(lockoutTime) - Date.now()) / 1000);
        showError(`Akun terkunci sementara. Coba lagi dalam ${wait} detik.`);
        return;
      }

      btn.disabled = true;
      const originalBtnHtml = btn.innerHTML;
      btn.innerHTML = `<span class="relative z-10 flex items-center gap-2"><svg class="animate-spin -ml-1 mr-2 h-5 w-5 text-white" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24"><circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle><path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path></svg> Memverifikasi...</span>`;
      
      let loginSuccess = false;

      try {
        const pwHash = await sha256(password);
        const authHash = await sha256(username + '|' + pwHash);
        const user   = usersData[username];

        if (!user || user.auth_hash !== authHash) {
          let attempts = parseInt(localStorage.getItem(attemptsKey) || '0') + 1;
          localStorage.setItem(attemptsKey, attempts);
          if (attempts >= 3) {
            localStorage.setItem(lockoutKey, Date.now() + 30000); 
            showError('Terlalu banyak percobaan. Silakan tunggu 30 detik.');
          } else {
            showError('Username atau Password salah.');
          }
          return;
        }
        
        localStorage.removeItem(attemptsKey);
        localStorage.removeItem(lockoutKey);

        if (user.role !== currentRole) {
          showError(`Akun ini bukan role "${currentRole}". Pilih tab yang sesuai.`);
          return;
        }

        // Establish PHP session for secure API operations
        if (user.role === 'admin' || user.role === 'guru') {
            let apiRes;
            try {
                apiRes = await fetch('/api/login.php', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ username, password })
                });
            } catch (netErr) {
                showError('Tidak dapat terhubung ke server. Pastikan server PHP aktif dan coba lagi.');
                return;
            }
            
            if (!apiRes.ok) {
                showError('Gagal membuat sesi dengan server. Coba refresh halaman dan login kembali.');
                return;
            }
        }

        sessionStorage.setItem('auth', JSON.stringify({
          username, nama: user.nama, role: user.role,
          kelas: user.kelas, nisn_hash: user.nisn_hash,
        }));

        loginSuccess = true;
        window.location.href = user.role === 'siswa' ? '/siswa' : '/dashboard';

      } finally {
        if (!loginSuccess) {
          btn.disabled = false;
          btn.innerHTML = originalBtnHtml;
        }
      }
    });
  });
  </script>
</BaseLayout>
