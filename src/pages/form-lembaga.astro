---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Form Identitas Lembaga" description="Isi profil sekolah dan identitas lembaga untuk keperluan SKL.">
  <div class="min-h-screen bg-slate-50 dark:bg-[#0B0F19] flex flex-col font-poppins relative selection:bg-indigo-500/30">
    <!-- Dekorasi Background -->
    <div class="fixed inset-0 overflow-hidden pointer-events-none z-0">
        <div class="absolute top-[-10%] left-[-10%] w-[40%] h-[40%] rounded-full bg-indigo-500/10 dark:bg-indigo-500/5 blur-[100px]"></div>
        <div class="absolute bottom-[-10%] right-[-10%] w-[40%] h-[40%] rounded-full bg-emerald-500/10 dark:bg-emerald-500/5 blur-[100px]"></div>
    </div>

    <!-- Header -->
    <header class="relative z-50 w-full bg-white/70 dark:bg-[#111827]/70 backdrop-blur-xl border-b border-slate-200 dark:border-slate-800 sticky top-0">
        <div class="max-w-4xl mx-auto px-6 py-4 flex items-center justify-between">
            <div class="flex items-center gap-3">
                <div class="w-10 h-10 rounded-xl bg-gradient-to-br from-indigo-500 to-violet-600 flex items-center justify-center text-white shadow-lg shadow-indigo-500/20">
                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"/></svg>
                </div>
                <div>
                    <h1 class="text-lg font-black font-outfit text-slate-800 dark:text-white leading-tight">Form Identitas</h1>
                    <p class="text-[11px] font-medium text-slate-500 dark:text-slate-400" id="header-lembaga-nama">Memuat...</p>
                </div>
            </div>
            <div>
                <span class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-lg text-xs font-bold bg-indigo-50 text-indigo-600 dark:bg-indigo-500/10 dark:text-indigo-400 border border-indigo-100 dark:border-indigo-500/20">
                    <span class="relative flex h-2 w-2">
                        <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-indigo-400 opacity-75"></span>
                        <span class="relative inline-flex rounded-full h-2 w-2 bg-indigo-500"></span>
                    </span>
                    Akses Publik
                </span>
            </div>
        </div>
    </header>

    <main class="relative z-10 flex-1 w-full max-w-4xl mx-auto px-6 py-8 md:py-12 flex flex-col items-center justify-center min-h-[60vh]" id="main-container">
        <!-- Loader State -->
        <div id="loader-state" class="flex flex-col items-center justify-center space-y-4">
            <svg class="w-8 h-8 animate-spin text-indigo-500" viewBox="0 0 24 24" fill="none"><circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"/><path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4z"/></svg>
            <p class="text-sm font-medium text-slate-500">Memeriksa token akses...</p>
        </div>

        <!-- Error State -->
        <div id="error-state" class="hidden flex-col items-center justify-center text-center max-w-md w-full bg-white dark:bg-[#111827] border border-slate-200 dark:border-slate-800 rounded-[2.5rem] p-10 md:p-14 shadow-2xl shadow-rose-500/10 relative overflow-hidden group">
            <!-- Decorative Elements -->
            <div class="absolute -top-12 -right-12 w-32 h-32 bg-rose-500/10 rounded-full blur-3xl group-hover:bg-rose-500/20 transition-all duration-700"></div>
            <div class="absolute -bottom-12 -left-12 w-32 h-32 bg-indigo-500/10 rounded-full blur-3xl group-hover:bg-indigo-500/20 transition-all duration-700"></div>
            
            <div class="relative">
                <div class="w-24 h-24 rounded-3xl bg-gradient-to-br from-rose-50 to-rose-100 dark:from-rose-500/10 dark:to-rose-500/20 flex items-center justify-center text-rose-500 mb-8 mx-auto rotate-3 group-hover:rotate-6 transition-transform duration-500 shadow-inner">
                    <svg class="w-12 h-12" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m0-8V7m0 8a1 1 0 110-2 1 1 0 010 2zm0-8a1 1 0 110-2 1 1 0 010 2zM3.34 16c-.77 1.333.192 3 1.732 3h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"/>
                    </svg>
                </div>
                
                <h2 class="text-3xl font-black font-outfit text-slate-800 dark:text-white mb-3 tracking-tight" id="error-title">Akses Ditolak</h2>
                <div class="h-1 w-12 bg-rose-500 mx-auto rounded-full mb-6"></div>
                <p class="text-base text-slate-600 dark:text-slate-400 mb-8 leading-relaxed" id="error-message">Token tidak valid atau telah kadaluarsa. Silakan hubungi admin untuk mendapatkan akses baru.</p>
                
                <a href="/" class="inline-flex items-center gap-2 px-6 py-3 rounded-2xl bg-slate-100 hover:bg-slate-200 dark:bg-slate-800 dark:hover:bg-slate-700 text-slate-700 dark:text-slate-200 font-bold text-sm transition-all active:scale-95">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"/></svg>
                    Kembali ke Beranda
                </a>
            </div>
        </div>

        <!-- Form State -->
        <div id="form-state" class="hidden w-full max-w-3xl mx-auto">
            <!-- Step Indicator -->
            <div class="mb-10 relative">
                <div class="flex justify-between items-center relative z-10">
                    <!-- Step 1 -->
                    <div class="flex flex-col items-center group cursor-pointer" onclick="goToStep(1)">
                        <div id="step-dot-1" class="w-10 h-10 rounded-full bg-indigo-600 text-white flex items-center justify-center font-bold transition-all shadow-lg shadow-indigo-500/20 ring-4 ring-white dark:ring-[#0B0F19]">1</div>
                        <span class="text-[10px] font-bold text-indigo-600 dark:text-indigo-400 mt-2 uppercase tracking-tighter">Profil</span>
                    </div>
                    <!-- Step 2 -->
                    <div class="flex flex-col items-center group cursor-pointer" onclick="goToStep(2)">
                        <div id="step-dot-2" class="w-10 h-10 rounded-full bg-slate-200 dark:bg-slate-800 text-slate-500 flex items-center justify-center font-bold transition-all ring-4 ring-white dark:ring-[#0B0F19]">2</div>
                        <span class="text-[10px] font-bold text-slate-400 mt-2 uppercase tracking-tighter">Dokumen</span>
                    </div>
                    <!-- Step 3 -->
                    <div class="flex flex-col items-center group cursor-pointer" onclick="goToStep(3)">
                        <div id="step-dot-3" class="w-10 h-10 rounded-full bg-slate-200 dark:bg-slate-800 text-slate-500 flex items-center justify-center font-bold transition-all ring-4 ring-white dark:ring-[#0B0F19]">3</div>
                        <span class="text-[10px] font-bold text-slate-400 mt-2 uppercase tracking-tighter">Kontak</span>
                    </div>
                </div>
                <!-- Progress Line -->
                <div class="absolute top-5 left-0 w-full h-[2px] bg-slate-200 dark:bg-slate-800 -z-0">
                    <div id="step-progress-bar" class="h-full bg-indigo-500 transition-all duration-500 w-0"></div>
                </div>
            </div>

            <form id="form-identitas" novalidate class="bg-white dark:bg-[#111827] border border-slate-200 dark:border-slate-800 rounded-3xl shadow-2xl shadow-indigo-500/5 overflow-hidden transition-all duration-300">
                <!-- STEP 1: PROFIL DASAR -->
                <div id="step-content-1" class="step-content p-6 md:p-10">
                    <div class="mb-8">
                        <div class="flex items-center gap-3 mb-2">
                            <span class="w-8 h-8 rounded-lg bg-indigo-500/10 text-indigo-500 flex items-center justify-center">
                                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"/></svg>
                            </span>
                            <h2 class="text-2xl font-black font-outfit text-slate-800 dark:text-white">Profil Institusi</h2>
                        </div>
                        <p class="text-sm text-slate-500 dark:text-slate-400">Informasi dasar mengenai identitas sekolah Anda.</p>
                    </div>

                    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                        <div class="md:col-span-2">
                            <label class="block text-xs font-bold text-slate-500 dark:text-slate-400 uppercase tracking-widest mb-2">Nama Lembaga <span class="text-rose-500">*</span></label>
                            <input type="text" id="input-sekolah" data-required="true" class="w-full bg-slate-50 dark:bg-[#0F1523] border border-slate-200 dark:border-slate-700 rounded-xl py-3.5 px-4 text-sm text-slate-800 dark:text-white focus:border-indigo-500 focus:bg-white dark:focus:bg-[#0B0F19] focus:ring-4 focus:ring-indigo-500/10 outline-none transition-all">
                        </div>
                        <div>
                            <label class="block text-xs font-bold text-slate-500 dark:text-slate-400 uppercase tracking-widest mb-2">Tahun Ajaran <span class="text-rose-500">*</span></label>
                            <input type="text" id="input-tapel" data-required="true" placeholder="2025/2026" class="w-full bg-slate-50 dark:bg-[#0F1523] border border-slate-200 dark:border-slate-700 rounded-xl py-3.5 px-4 text-sm text-slate-800 dark:text-white focus:border-indigo-500 focus:bg-white dark:focus:bg-[#0B0F19] focus:ring-4 focus:ring-indigo-500/10 outline-none transition-all">
                        </div>
                        <div>
                            <label class="block text-xs font-bold text-slate-500 dark:text-slate-400 uppercase tracking-widest mb-2">Jenjang Sekolah <span class="text-rose-500">*</span></label>
                            <select id="input-jenjang" class="w-full bg-slate-50 dark:bg-[#0F1523] border border-slate-200 dark:border-slate-700 rounded-xl py-3.5 px-4 text-sm text-slate-800 dark:text-white focus:border-indigo-500 focus:bg-white dark:focus:bg-[#0B0F19] focus:ring-4 focus:ring-indigo-500/10 outline-none transition-all cursor-pointer appearance-none">
                                <option value="SMP">SMP</option><option value="SMA">SMA</option><option value="SMK">SMK</option><option value="MA">MA</option><option value="MTs">MTs</option>
                            </select>
                        </div>
                        <div>
                            <label class="block text-xs font-bold text-slate-500 dark:text-slate-400 uppercase tracking-widest mb-2">NPSN <span class="text-rose-500">*</span></label>
                            <input type="text" id="input-npsn" data-required="true" class="w-full bg-slate-50 dark:bg-[#0F1523] border border-slate-200 dark:border-slate-700 rounded-xl py-3.5 px-4 text-sm text-slate-800 dark:text-white focus:border-indigo-500 focus:bg-white dark:focus:bg-[#0B0F19] focus:ring-4 focus:ring-indigo-500/10 outline-none transition-all">
                        </div>
                        <div>
                            <label class="block text-xs font-bold text-slate-500 dark:text-slate-400 uppercase tracking-widest mb-2">NSS <span class="text-rose-500">*</span></label>
                            <input type="text" id="input-nss" data-required="true" class="w-full bg-slate-50 dark:bg-[#0F1523] border border-slate-200 dark:border-slate-700 rounded-xl py-3.5 px-4 text-sm text-slate-800 dark:text-white focus:border-indigo-500 focus:bg-white dark:focus:bg-[#0B0F19] focus:ring-4 focus:ring-indigo-500/10 outline-none transition-all">
                        </div>
                        <div>
                            <label class="block text-xs font-bold text-slate-500 dark:text-slate-400 uppercase tracking-widest mb-2">Kurikulum</label>
                            <select id="input-kurikulum" class="w-full bg-slate-50 dark:bg-[#0F1523] border border-slate-200 dark:border-slate-700 rounded-xl py-3.5 px-4 text-sm text-slate-800 dark:text-white focus:border-indigo-500 focus:bg-white dark:focus:bg-[#0B0F19] focus:ring-4 focus:ring-indigo-500/10 outline-none transition-all cursor-pointer appearance-none">
                                <option value="Kurikulum Merdeka">Kurikulum Merdeka</option>
                                <option value="Kurikulum 2013">Kurikulum 2013</option>
                                <option value="Kurikulum 2013 Revisi">Kurikulum 2013 Revisi</option>
                                <option value="KTSP">KTSP</option>
                            </select>
                        </div>
                        <div id="wrap-konsentrasi" class="hidden">
                            <label class="block text-xs font-bold text-slate-500 dark:text-slate-400 uppercase tracking-widest mb-2">Konsentrasi Keahlian (SMK)</label>
                            <input type="text" id="input-konsentrasi" class="w-full bg-slate-50 dark:bg-[#0F1523] border border-slate-200 dark:border-slate-700 rounded-xl py-3.5 px-4 text-sm text-slate-800 dark:text-white focus:border-indigo-500 focus:bg-white dark:focus:bg-[#0B0F19] focus:ring-4 focus:ring-indigo-500/10 outline-none transition-all">
                        </div>
                    </div>
                </div>

                <!-- STEP 2: DOKUMEN & PENGATURAN -->
                <div id="step-content-2" class="step-content hidden p-6 md:p-10">
                    <div class="mb-8">
                        <div class="flex items-center gap-3 mb-2">
                            <span class="w-8 h-8 rounded-lg bg-emerald-500/10 text-emerald-500 flex items-center justify-center">
                                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/></svg>
                            </span>
                            <h2 class="text-2xl font-black font-outfit text-slate-800 dark:text-white">Dokumen & SKL</h2>
                        </div>
                        <p class="text-sm text-slate-500 dark:text-slate-400">Pengaturan tanggal rilis dan format penomoran surat.</p>
                    </div>

                    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                        <div>
                            <label class="block text-xs font-bold text-slate-500 dark:text-slate-400 uppercase tracking-widest mb-2 flex items-center gap-1"><span class="text-emerald-500">●</span> Tgl Pengumuman SKL 1 <span class="text-rose-500">*</span></label>
                            <input type="date" id="input-tgl" data-required="true" class="date-input w-full bg-slate-50 dark:bg-[#0F1523] border border-slate-200 dark:border-slate-700 rounded-xl py-3.5 px-4 text-sm text-slate-800 dark:text-white focus:border-indigo-500 focus:bg-white dark:focus:bg-[#0B0F19] focus:ring-4 focus:ring-indigo-500/10 outline-none transition-all">
                        </div>
                        <div>
                            <label class="block text-xs font-bold text-slate-500 dark:text-slate-400 uppercase tracking-widest mb-2 flex items-center gap-1"><span class="text-indigo-500">●</span> Tgl SKL 2 (Nilai)</label>
                            <input type="date" id="input-tgl-skl2" class="date-input w-full bg-slate-50 dark:bg-[#0F1523] border border-slate-200 dark:border-slate-700 rounded-xl py-3.5 px-4 text-sm text-slate-800 dark:text-white focus:border-indigo-500 focus:bg-white dark:focus:bg-[#0B0F19] focus:ring-4 focus:ring-indigo-500/10 outline-none transition-all">
                        </div>
                        <div class="md:col-span-2">
                            <label class="block text-xs font-bold text-slate-500 dark:text-slate-400 uppercase tracking-widest mb-3">Format Nomor Surat <span class="text-rose-500">*</span></label>
                            <div class="grid grid-cols-2 gap-3 mb-4">
                                <label class="relative flex items-start gap-3 p-4 rounded-xl border-2 border-slate-200 dark:border-slate-700 cursor-pointer transition-all hover:border-indigo-400 has-[:checked]:border-indigo-500 has-[:checked]:bg-indigo-50 dark:has-[:checked]:bg-indigo-500/10">
                                    <input type="radio" name="nomor_surat_mode" id="mode-auto" value="auto" class="mt-0.5 accent-indigo-600">
                                    <div>
                                        <p class="text-sm font-bold text-slate-800 dark:text-white">Auto Number</p>
                                        <p class="text-[10px] text-slate-500">Otomatis per siswa</p>
                                    </div>
                                </label>
                                <label class="relative flex items-start gap-3 p-4 rounded-xl border-2 border-slate-200 dark:border-slate-700 cursor-pointer transition-all hover:border-violet-400 has-[:checked]:border-violet-500 has-[:checked]:bg-violet-50 dark:has-[:checked]:bg-violet-500/10">
                                    <input type="radio" name="nomor_surat_mode" id="mode-static" value="static" class="mt-0.5 accent-violet-600">
                                    <div>
                                        <p class="text-sm font-bold text-slate-800 dark:text-white">Statis</p>
                                        <p class="text-[10px] text-slate-500">Satu nomor tetap</p>
                                    </div>
                                </label>
                            </div>
                            <div id="section-nomor-auto">
                                <div class="flex items-center bg-slate-50 dark:bg-[#0F1523] border border-slate-200 dark:border-slate-700 rounded-xl overflow-hidden focus-within:border-indigo-500 transition-all">
                                    <span class="px-4 text-slate-400 text-xs font-mono border-r border-slate-200 dark:border-slate-700 py-3.5 bg-slate-100 dark:bg-slate-800/50">XXX</span>
                                    <input type="text" id="input-nomor-surat" placeholder="/SMK/IV/2026" class="flex-1 bg-transparent py-3.5 px-3 text-sm text-slate-800 dark:text-white outline-none font-mono">
                                </div>
                            </div>
                            <div id="section-nomor-static" class="hidden">
                                <input type="text" id="input-nomor-surat-statis" placeholder="123/SMK/IV/2026" class="w-full bg-slate-50 dark:bg-[#0F1523] border border-slate-200 dark:border-slate-700 rounded-xl py-3.5 px-4 text-sm text-slate-800 dark:text-white focus:border-violet-500 outline-none font-mono">
                            </div>
                        </div>
                        <div class="md:col-span-2">
                            <label class="block text-xs font-bold text-slate-500 dark:text-slate-400 uppercase tracking-widest mb-2">Website / Domain Sekolah</label>
                            <div class="flex items-center bg-slate-50 dark:bg-[#0F1523] border border-slate-200 dark:border-slate-700 rounded-xl overflow-hidden focus-within:border-indigo-500 transition-all">
                                <span class="px-4 text-slate-400 text-sm font-mono border-r border-slate-200 dark:border-slate-700 py-3.5 bg-slate-100 dark:bg-slate-800/50">https://</span>
                                <input type="text" id="input-domain" placeholder="namadomain.com" class="flex-1 bg-transparent py-3.5 px-3 text-sm text-slate-800 dark:text-white outline-none font-mono">
                            </div>
                        </div>
                        <div class="md:col-span-2">
                            <label class="block text-xs font-bold text-slate-500 dark:text-slate-400 uppercase tracking-widest mb-2">Pengumuman Tambahan</label>
                            <link href="https://cdn.quilljs.com/1.3.6/quill.snow.css" rel="stylesheet">
                            <div class="quill-wrapper bg-slate-50 dark:bg-[#0F1523] border border-slate-200 dark:border-slate-700 rounded-xl overflow-hidden transition-all focus-within:border-indigo-500 focus-within:ring-4 focus-within:ring-indigo-500/10">
                                <div id="editor-pengumuman" class="text-sm text-slate-800 dark:text-white bg-transparent" style="min-height: 120px;"></div>
                            </div>
                            <textarea id="input-pengumuman" class="hidden"></textarea>
                        </div>
                    </div>
                </div>

                <!-- STEP 3: KONTAK & KEPSEK -->
                <div id="step-content-3" class="step-content hidden p-6 md:p-10">
                    <div class="mb-8">
                        <div class="flex items-center gap-3 mb-2">
                            <span class="w-8 h-8 rounded-lg bg-violet-500/10 text-violet-500 flex items-center justify-center">
                                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/></svg>
                            </span>
                            <h2 class="text-2xl font-black font-outfit text-slate-800 dark:text-white">Kontak & Kepsek</h2>
                        </div>
                        <p class="text-sm text-slate-500 dark:text-slate-400">Informasi kontak sekolah dan identitas Kepala Sekolah.</p>
                    </div>

                    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                        <div>
                            <label class="block text-xs font-bold text-slate-500 dark:text-slate-400 uppercase tracking-widest mb-2">Telepon</label>
                            <input type="text" id="input-telepon" class="w-full bg-slate-50 dark:bg-[#0F1523] border border-slate-200 dark:border-slate-700 rounded-xl py-3.5 px-4 text-sm text-slate-800 dark:text-white focus:border-indigo-500 outline-none transition-all">
                        </div>
                        <div>
                            <label class="block text-xs font-bold text-slate-500 dark:text-slate-400 uppercase tracking-widest mb-2">Email</label>
                            <input type="email" id="input-email" class="w-full bg-slate-50 dark:bg-[#0F1523] border border-slate-200 dark:border-slate-700 rounded-xl py-3.5 px-4 text-sm text-slate-800 dark:text-white focus:border-indigo-500 outline-none transition-all">
                        </div>
                        <div class="md:col-span-2">
                            <label class="block text-xs font-bold text-slate-500 dark:text-slate-400 uppercase tracking-widest mb-2">Alamat Lengkap <span class="text-rose-500">*</span></label>
                            <textarea id="input-alamat" rows="2" data-required="true" class="w-full bg-slate-50 dark:bg-[#0F1523] border border-slate-200 dark:border-slate-700 rounded-xl py-3.5 px-4 text-sm text-slate-800 dark:text-white focus:border-indigo-500 outline-none transition-all resize-none"></textarea>
                        </div>
                        <!-- Searchable Provinsi -->
                        <div>
                            <label class="block text-xs font-bold text-slate-500 dark:text-slate-400 uppercase tracking-widest mb-2">Provinsi <span class="text-rose-500">*</span></label>
                            <div class="searchable-select" id="wrap-provinsi" style="position:relative">
                                <input type="hidden" id="input-provinsi" data-required="true" />
                                <button type="button" class="ss-trigger w-full bg-slate-50 dark:bg-[#0F1523] border border-slate-200 dark:border-slate-700 rounded-xl py-3.5 px-4 text-sm text-left text-slate-400 dark:text-slate-500 focus:border-indigo-500 focus:ring-4 focus:ring-indigo-500/10 outline-none transition-all flex items-center justify-between" id="trig-provinsi">
                                    <span class="ss-label truncate">— Pilih Provinsi —</span>
                                    <svg class="w-4 h-4 text-slate-400 flex-shrink-0 transition-transform ss-chevron" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
                                </button>
                                <div class="ss-dropdown hidden absolute z-50 mt-1 left-0 right-0 bg-white dark:bg-[#111827] border border-slate-200 dark:border-slate-700 rounded-xl shadow-xl overflow-hidden">
                                    <div class="p-2 border-b border-slate-100 dark:border-slate-800">
                                        <input type="text" class="ss-search w-full bg-slate-50 dark:bg-[#0F1523] border border-slate-200 dark:border-slate-700 rounded-lg py-2 px-3 text-xs text-slate-800 dark:text-white outline-none focus:border-indigo-500 transition-all" placeholder="Cari provinsi..." autocomplete="off">
                                    </div>
                                    <ul class="ss-list max-h-48 overflow-y-auto py-1 text-sm"></ul>
                                </div>
                            </div>
                        </div>
                        <!-- Searchable Kabupaten/Kota -->
                        <div>
                            <label class="block text-xs font-bold text-slate-500 dark:text-slate-400 uppercase tracking-widest mb-2">Kabupaten/Kota <span class="text-rose-500">*</span></label>
                            <div class="searchable-select" id="wrap-kota" style="position:relative">
                                <input type="hidden" id="input-kota" data-required="true" />
                                <button type="button" class="ss-trigger w-full bg-slate-50 dark:bg-[#0F1523] border border-slate-200 dark:border-slate-700 rounded-xl py-3.5 px-4 text-sm text-left text-slate-400 dark:text-slate-500 focus:border-indigo-500 focus:ring-4 focus:ring-indigo-500/10 outline-none transition-all flex items-center justify-between" id="trig-kota">
                                    <span class="ss-label truncate">— Pilih Kabupaten/Kota —</span>
                                    <svg class="w-4 h-4 text-slate-400 flex-shrink-0 transition-transform ss-chevron" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
                                </button>
                                <div class="ss-dropdown hidden absolute z-50 mt-1 left-0 right-0 bg-white dark:bg-[#111827] border border-slate-200 dark:border-slate-700 rounded-xl shadow-xl overflow-hidden">
                                    <div class="p-2 border-b border-slate-100 dark:border-slate-800">
                                        <input type="text" class="ss-search w-full bg-slate-50 dark:bg-[#0F1523] border border-slate-200 dark:border-slate-700 rounded-lg py-2 px-3 text-xs text-slate-800 dark:text-white outline-none focus:border-indigo-500 transition-all" placeholder="Cari kabupaten/kota..." autocomplete="off">
                                    </div>
                                    <ul class="ss-list max-h-48 overflow-y-auto py-1 text-sm"></ul>
                                </div>
                            </div>
                        </div>
                        <div class="md:col-span-2 mt-4 pt-4 border-t border-slate-100 dark:border-slate-800">
                            <label class="block text-xs font-bold text-slate-500 dark:text-slate-400 uppercase tracking-widest mb-2">Nama Kepala Sekolah <span class="text-rose-500">*</span></label>
                            <input type="text" id="input-kepsek" data-required="true" class="w-full bg-slate-50 dark:bg-[#0F1523] border border-slate-200 dark:border-slate-700 rounded-xl py-3.5 px-4 text-sm text-slate-800 dark:text-white focus:border-indigo-500 outline-none transition-all">
                        </div>
                        <div class="md:col-span-2">
                            <label class="block text-xs font-bold text-slate-500 dark:text-slate-400 uppercase tracking-widest mb-3 mt-1">ID Tampil di SKL <span class="text-rose-500">*</span></label>
                            <div class="grid grid-cols-2 gap-3 max-w-sm">
                                <label class="relative flex items-center justify-center gap-2 p-3.5 rounded-xl border-2 border-slate-200 dark:border-slate-700 cursor-pointer transition-all hover:border-indigo-400 has-[:checked]:border-indigo-500 has-[:checked]:bg-indigo-50 dark:has-[:checked]:bg-indigo-500/10 text-slate-500 dark:text-slate-400 has-[:checked]:text-indigo-600 dark:has-[:checked]:text-indigo-400">
                                    <input type="radio" name="id_kepsek_mode" id="mode-id-nip" value="nip" class="sr-only" data-required="true">
                                    <span class="text-sm font-bold">NIP</span>
                                </label>
                                <label class="relative flex items-center justify-center gap-2 p-3.5 rounded-xl border-2 border-slate-200 dark:border-slate-700 cursor-pointer transition-all hover:border-violet-400 has-[:checked]:border-violet-500 has-[:checked]:bg-violet-50 dark:has-[:checked]:bg-violet-500/10 text-slate-500 dark:text-slate-400 has-[:checked]:text-violet-600 dark:has-[:checked]:text-violet-400">
                                    <input type="radio" name="id_kepsek_mode" id="mode-id-nuptk" value="nuptk" class="sr-only" data-required="true">
                                    <span class="text-sm font-bold">NUPTK</span>
                                </label>
                            </div>
                        </div>
                        <div id="section-nip">
                            <label class="block text-xs font-bold text-slate-500 dark:text-slate-400 uppercase tracking-widest mb-2">Nomor NIP</label>
                            <input type="text" id="input-nip" class="w-full bg-slate-50 dark:bg-[#0F1523] border border-slate-200 dark:border-slate-700 rounded-xl py-3.5 px-4 text-sm text-slate-800 dark:text-white focus:border-indigo-500 outline-none transition-all">
                        </div>
                        <div id="section-nuptk" class="hidden">
                            <label class="block text-xs font-bold text-slate-500 dark:text-slate-400 uppercase tracking-widest mb-2">Nomor NUPTK</label>
                            <input type="text" id="input-nuptk" class="w-full bg-slate-50 dark:bg-[#0F1523] border border-slate-200 dark:border-slate-700 rounded-xl py-3.5 px-4 text-sm text-slate-800 dark:text-white focus:border-violet-500 outline-none transition-all">
                        </div>
                    </div>
                </div>

                <!-- Navigation Bar -->
                <div class="bg-slate-50 dark:bg-slate-800/30 px-6 py-6 border-t border-slate-100 dark:border-slate-800 flex items-center justify-between">
                    <button type="button" id="btn-prev" class="invisible px-6 py-3 text-sm font-bold text-slate-500 dark:text-slate-400 hover:text-indigo-600 dark:hover:text-indigo-400 flex items-center gap-2 transition-all">
                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/></svg>
                        Kembali
                    </button>
                    
                    <div class="flex gap-3">
                        <button type="button" id="btn-next" class="px-8 py-3.5 bg-slate-800 dark:bg-slate-700 hover:bg-slate-700 dark:hover:bg-slate-600 text-white rounded-xl font-bold font-outfit shadow-lg shadow-indigo-500/10 transition-all hover:-translate-y-0.5 flex items-center gap-2">
                            Lanjut
                            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
                        </button>
                        <button type="submit" id="btn-submit" class="hidden px-8 py-3.5 bg-gradient-to-r from-indigo-600 to-violet-600 hover:from-indigo-500 hover:to-violet-500 text-white rounded-xl font-bold font-outfit shadow-lg shadow-indigo-500/30 transition-all hover:-translate-y-0.5 flex items-center gap-2">
                            Simpan Perubahan
                            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3"/></svg>
                        </button>
                    </div>
                </div>
            </form>
            
            <div class="mt-8 text-center">
                <p class="text-xs text-slate-500 dark:text-slate-400">
                    Sistem Manajemen Kelulusan &copy; {new Date().getFullYear()}
                </p>
            </div>
        </div>
    </main>

    <script src="https://cdn.quilljs.com/1.3.6/quill.min.js" is:inline></script>
    <script src="/js/dash-util.js" is:inline></script>
    <script src="/js/wilayah-data.js" is:inline></script>
    <script is:inline>
        let currentStep = 1;
        const totalSteps = 3;

        window.goToStep = (n) => {
            if (n === currentStep) return;
            // For simplicity, allow going to any step via dots, but in practice you might want to validate
            showStep(n);
        };

        function showStep(n) {
            currentStep = n;

            // Update Sections visibility
            document.querySelectorAll('.step-content').forEach((el, index) => {
                el.classList.toggle('hidden', index + 1 !== n);
            });

            // Update Dots & Progress UI
            for (let i = 1; i <= totalSteps; i++) {
                const dot = document.getElementById(`step-dot-${i}`);
                const span = dot.nextElementSibling;
                
                if (i < n) {
                    // Completed Step
                    dot.classList.remove('bg-slate-200', 'dark:bg-slate-800', 'text-slate-500', 'bg-indigo-600', 'text-white');
                    dot.classList.add('bg-emerald-500', 'text-white');
                    dot.innerHTML = '<svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7"/></svg>';
                    if (span) {
                        span.classList.remove('text-slate-400', 'text-indigo-600', 'dark:text-indigo-400');
                        span.classList.add('text-emerald-500');
                    }
                } else if (i === n) {
                    // Active Step
                    dot.classList.remove('bg-slate-200', 'dark:bg-slate-800', 'text-slate-500', 'bg-emerald-500');
                    dot.classList.add('bg-indigo-600', 'text-white');
                    dot.innerHTML = i;
                    if (span) {
                        span.classList.remove('text-slate-400', 'text-emerald-500');
                        span.classList.add('text-indigo-600', 'dark:text-indigo-400');
                    }
                } else {
                    // Pending Step
                    dot.classList.remove('bg-indigo-600', 'text-white', 'bg-emerald-500');
                    dot.classList.add('bg-slate-200', 'dark:bg-slate-800', 'text-slate-500');
                    dot.innerHTML = i;
                    if (span) {
                        span.classList.remove('text-indigo-600', 'dark:text-indigo-400', 'text-emerald-500');
                        span.classList.add('text-slate-400');
                    }
                }
            }

            // Update Progress Bar width
            const progressBar = document.getElementById('step-progress-bar');
            if (progressBar) {
                const progress = ((n - 1) / (totalSteps - 1)) * 100;
                progressBar.style.width = `${progress}%`;
            }

            // Button visibility management
            const btnPrev = document.getElementById('btn-prev');
            const btnNext = document.getElementById('btn-next');
            const btnSubmit = document.getElementById('btn-submit');

            if (btnPrev) btnPrev.classList.toggle('invisible', n === 1);
            if (btnNext) btnNext.classList.toggle('hidden', n === totalSteps);
            if (btnSubmit) btnSubmit.classList.toggle('hidden', n !== totalSteps);
            
            // Auto scroll to form header for better visibility
            const formContainer = document.getElementById('form-state');
            if (formContainer) {
                const yOffset = -100; 
                const y = formContainer.getBoundingClientRect().top + window.pageYOffset + yOffset;
                window.scrollTo({top: y, behavior: 'smooth'});
            }
        }

        document.addEventListener('DOMContentLoaded', async () => {
            ssInitAll();
            const params = new URLSearchParams(window.location.search);
            const token = params.get('token');
            const loaderState = document.getElementById('loader-state');
            const errorState = document.getElementById('error-state');
            const formState = document.getElementById('form-state');
            const headerLembaga = document.getElementById('header-lembaga-nama');

            if (!token) {
                loaderState.classList.add('hidden');
                errorState.classList.remove('hidden');
                document.getElementById('error-message').textContent = 'Token akses tidak ditemukan pada URL.';
                return;
            }

            // Mapping Label untuk Validasi Kustom
            const fieldLabels = {
                'input-sekolah': 'Nama Sekolah',
                'input-npsn': 'NPSN',
                'input-tapel': 'Tahun Pelajaran',
                'input-tgl': 'Tanggal Pengumuman',
                'input-telepon': 'Nomor Telepon',
                'input-email': 'Email',
                'input-kepsek': 'Nama Kepala Sekolah',
                'input-nip': 'NIP Kepala Sekolah',
                'input-nuptk': 'NUPTK Kepala Sekolah',
                'input-provinsi': 'Provinsi',
                'input-kota': 'Kabupaten/Kota',
                'input-alamat': 'Alamat Lengkap'
            };

            // Fungsi Validasi Kustom
            function validateForm(step = null) {
                let errors = [];
                const targetSelector = step ? `#step-content-${step}` : '#form-identitas';
                const container = document.querySelector(targetSelector);
                const requiredInputs = container.querySelectorAll('input[data-required="true"], select[data-required="true"], textarea[data-required="true"]');

                // 1. Validasi Field Kosong
                requiredInputs.forEach(input => {
                    // Cek jika field tersembunyi
                    const isHidden = input.closest('.hidden');
                    if (isHidden) return;

                    if (!input.value.trim()) {
                        const label = fieldLabels[input.id] || 'Kolom wajib';
                        errors.push(`<b>${label}</b> tidak boleh kosong.`);
                        if (input.type === 'hidden' && input.parentElement.classList.contains('searchable-select')) {
                            const trigger = input.parentElement.querySelector('.ss-trigger');
                            if (trigger) trigger.classList.add('border-rose-500', 'bg-rose-50/30', 'dark:bg-rose-500/5');
                        } else {
                            input.classList.add('border-rose-500', 'bg-rose-50/30', 'dark:bg-rose-500/5');
                        }
                    } else {
                        if (input.type === 'hidden' && input.parentElement.classList.contains('searchable-select')) {
                            const trigger = input.parentElement.querySelector('.ss-trigger');
                            if (trigger) trigger.classList.remove('border-rose-500', 'bg-rose-50/30', 'dark:bg-rose-500/5');
                        } else {
                            input.classList.remove('border-rose-500', 'bg-rose-50/30', 'dark:bg-rose-500/5');
                        }
                    }
                });

                // 2. Validasi Format Spesifik
                if (!step || step === 1) {
                    const npsnEl = document.getElementById('input-npsn');
                    if (npsnEl.value && !/^[0-9]{8}$/.test(npsnEl.value)) {
                        errors.push('<b>NPSN</b> harus terdiri dari 8 digit angka.');
                        npsnEl.classList.add('border-rose-500');
                    }
                }

                if (!step || step === 3) {
                    const emailEl = document.getElementById('input-email');
                    if (emailEl.value && !/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(emailEl.value)) {
                        errors.push('Format <b>Email</b> tidak valid.');
                        emailEl.classList.add('border-rose-500');
                    }
                }

                if (errors.length > 0) {
                    Swal.fire({
                        title: 'Periksa Kembali',
                        html: `
                            <div class="mt-2 text-left bg-slate-50 dark:bg-slate-800/50 rounded-2xl p-4 border border-slate-100 dark:border-slate-800">
                                <ul class="space-y-2">
                                    ${errors.map(err => `
                                        <li class="flex items-start gap-2 text-xs text-slate-600 dark:text-slate-400">
                                            <span class="text-amber-500 mt-0.5">●</span>
                                            <span>${err}</span>
                                        </li>
                                    `).join('')}
                                </ul>
                            </div>
                        `,
                        icon: 'warning',
                        confirmButtonColor: '#6366f1',
                        customClass: {
                            popup: 'swal-custom-popup',
                            title: 'swal-custom-title',
                            confirmButton: 'swal-custom-btn'
                        }
                    });
                    return false;
                }
                return true;
            }

            // Navigation Listeners
            document.getElementById('btn-next')?.addEventListener('click', () => {
                if (validateForm(currentStep)) {
                    if (currentStep < totalSteps) showStep(currentStep + 1);
                }
            });

            document.getElementById('btn-prev')?.addEventListener('click', () => {
                if (currentStep > 1) showStep(currentStep - 1);
            });

            // Init Quill
            let quillEditor;
            try {
                if (document.getElementById('editor-pengumuman') && typeof Quill !== 'undefined') {
                    quillEditor = new Quill('#editor-pengumuman', {
                        theme: 'snow',
                        modules: {
                            toolbar: [
                                ['bold', 'italic', 'underline', 'strike'],
                                [{ 'list': 'ordered'}, { 'list': 'bullet' }],
                                ['link', 'clean']
                            ]
                        },
                        placeholder: 'Tuliskan pengumuman tambahan seperti jadwal cap 3 jari, pengambilan SKHU, dll...'
                    });
                    quillEditor.on('text-change', function() {
                        const html = quillEditor.root.innerHTML;
                        document.getElementById('input-pengumuman').value = html;
                    });
                }
            } catch(e) {
                console.warn('Quill init error', e);
            }

            // Helper format date
            const parseTgl = (str) => {
                if(!str)return null;
                const p = str.split(/[-/]/);
                if(p.length===3){
                    if(p[0].length===4) return new Date(p[0],p[1]-1,p[2]); // yyyy-mm-dd
                    return new Date(p[2],p[1]-1,p[0]); // dd-mm-yyyy
                }
                return null;
            };

            // Fetch data
            try {
                const res = await fetch(`/api/form-lembaga.php?token=${token}`);
                const result = await res.json();

                loaderState.classList.add('hidden');

                if (!result.success) {
                    errorState.classList.remove('hidden');
                    document.getElementById('error-message').textContent = result.error || 'Terjadi kesalahan saat memvalidasi token.';
                    return;
                }

                formState.classList.remove('hidden');
                headerLembaga.textContent = result.lembaga.nama;

                // Prefill Form
                const m = result.data || {};
                const map = {
                    'sekolah': 'sekolah', 'npsn': 'npsn', 'nss': 'nss', 'tapel': 'tahun_ajaran',
                    'alamat': 'alamat', 'tgl': 'tanggal_pengumuman', 'domain': 'domain', 'konsentrasi': 'kompetensi_keahlian'
                };

                for (const [idKey, mKey] of Object.entries(map)) {
                    const el = document.getElementById(`input-${idKey}`);
                    if (el) {
                        let val = m[mKey] || '';
                        if (idKey === 'tgl' && val) {
                            const d = parseTgl(val);
                            if (d) val = `${d.getFullYear()}-${String(d.getMonth()+1).padStart(2,'0')}-${String(d.getDate()).padStart(2,'0')}`;
                        }
                        el.value = val;
                    }
                }
                
                if (document.getElementById('input-telepon')) document.getElementById('input-telepon').value = m.telepon || '';
                if (document.getElementById('input-email')) document.getElementById('input-email').value = m.email || '';
                if (document.getElementById('input-kepsek')) document.getElementById('input-kepsek').value = m.kepala_sekolah || '';
                if (document.getElementById('input-jabatan')) document.getElementById('input-jabatan').value = m.jabatan_kepsek || '';
                if (document.getElementById('input-nip')) document.getElementById('input-nip').value = m.nip_kepsek || '';
                if (document.getElementById('input-nuptk')) document.getElementById('input-nuptk').value = m.nuptk_kepsek || '';
                
                // Helper for text matching
                function toTitleCase(str) {
                    if (!str) return '';
                    return str.toLowerCase().replace(/\b\w/g, s => s.toUpperCase());
                }

                // Populate Provinsi & Kota via searchable-select
                setTimeout(() => {
                    if(typeof WILAYAH_DATA !== 'undefined'){
                        const dbProv = toTitleCase(m.provinsi || '');
                        let dbKota = toTitleCase(m.kota || '');
                        dbKota = dbKota.replace(/^(Kabupaten|Kota)\s+/i, '');

                        ssSetOptions('wrap-provinsi', Object.keys(WILAYAH_DATA), dbProv);
                        
                        const kotaList = (dbProv && WILAYAH_DATA[dbProv]) ? WILAYAH_DATA[dbProv] : [];
                        ssSetOptions('wrap-kota', kotaList, dbKota);
                        
                        // When provinsi changes → repopulate kota
                        const wrapProv = document.getElementById('wrap-provinsi');
                        if(wrapProv) wrapProv._ssOnChange = (prov) => {
                            const kl = (prov && WILAYAH_DATA[prov]) ? WILAYAH_DATA[prov] : [];
                            ssSetOptions('wrap-kota', kl, '');
                        };
                    }
                }, 800);

                if (document.getElementById('input-jenjang')) {
                    document.getElementById('input-jenjang').value = m.jenjang || 'SMA';
                    if (m.jenjang === 'SMK') document.getElementById('wrap-konsentrasi').classList.remove('hidden');
                }
                document.getElementById('input-jenjang').addEventListener('change', (e) => {
                    document.getElementById('wrap-konsentrasi').classList.toggle('hidden', e.target.value !== 'SMK');
                });

                if (document.getElementById('input-kurikulum')) document.getElementById('input-kurikulum').value = m.kurikulum || 'Kurikulum Merdeka';
                if (document.getElementById('input-nomor-surat')) document.getElementById('input-nomor-surat').value = m.nomor_surat_suffix || '';
                if (document.getElementById('input-nomor-surat-statis')) document.getElementById('input-nomor-surat-statis').value = m.nomor_surat_statis || '';
                
                if (document.getElementById('input-pengumuman')) {
                    document.getElementById('input-pengumuman').value = m.pengumuman || '';
                    if (quillEditor) quillEditor.root.innerHTML = m.pengumuman || '';
                }

                const nomorMode = m.nomor_surat_mode || 'auto';
                if (document.getElementById('mode-auto')) document.getElementById('mode-auto').checked = nomorMode === 'auto';
                if (document.getElementById('mode-static')) document.getElementById('mode-static').checked = nomorMode === 'static';
                document.getElementById('section-nomor-auto').classList.toggle('hidden', nomorMode !== 'auto');
                document.getElementById('section-nomor-static').classList.toggle('hidden', nomorMode !== 'static');

                const idKepsekMode = m.id_kepsek_mode || 'nip';
                if (document.getElementById('mode-id-nip')) document.getElementById('mode-id-nip').checked = idKepsekMode === 'nip';
                if (document.getElementById('mode-id-nuptk')) document.getElementById('mode-id-nuptk').checked = idKepsekMode === 'nuptk';
                document.getElementById('section-nip').classList.toggle('hidden', idKepsekMode !== 'nip');
                document.getElementById('section-nuptk').classList.toggle('hidden', idKepsekMode !== 'nuptk');

                if (document.getElementById('input-tgl-skl2')) {
                    let v = m.tanggal_skl2 || '';
                    if (v) {
                        const d = parseTgl(v);
                        if (d) v = `${d.getFullYear()}-${String(d.getMonth()+1).padStart(2,'0')}-${String(d.getDate()).padStart(2,'0')}`;
                    }
                    document.getElementById('input-tgl-skl2').value = v;
                }

                // Initial UI Sync for Step 1
                showStep(1);

            } catch (err) {
                loaderState.classList.add('hidden');
                errorState.classList.remove('hidden');
                document.getElementById('error-message').textContent = 'Terjadi kesalahan jaringan atau server saat memuat data.';
            }

            // Radio toggle listener
            document.querySelectorAll('[name="nomor_surat_mode"]').forEach(radio => {
                radio.onchange = () => {
                    const isStatic = document.getElementById('mode-static').checked;
                    document.getElementById('section-nomor-auto').classList.toggle('hidden', isStatic);
                    document.getElementById('section-nomor-static').classList.toggle('hidden', !isStatic);
                };
            });
            document.querySelectorAll('[name="id_kepsek_mode"]').forEach(radio => {
                radio.onchange = () => {
                    const isNuptk = document.getElementById('mode-id-nuptk').checked;
                    document.getElementById('section-nip').classList.toggle('hidden', isNuptk);
                    document.getElementById('section-nuptk').classList.toggle('hidden', !isNuptk);
                };
            });

            // Handle Submit
            document.getElementById('form-identitas').addEventListener('submit', async (e) => {
                e.preventDefault();
                
                // Final validation before submit
                if (!validateForm()) return;

                const rawDomain = (document.getElementById('input-domain').value || '').trim().replace(/^https?:\/\//,'');
                const nomorMode = document.getElementById('mode-static').checked ? 'static' : 'auto';
                const idKepsekMode = document.getElementById('mode-id-nuptk').checked ? 'nuptk' : 'nip';
                
                const payload = {
                    sekolah: document.getElementById('input-sekolah').value,
                    npsn: document.getElementById('input-npsn').value,
                    nss: document.getElementById('input-nss').value,
                    jenjang: document.getElementById('input-jenjang').value || 'SMA',
                    kurikulum: document.getElementById('input-kurikulum').value || 'Kurikulum Merdeka',
                    kompetensi_keahlian: document.getElementById('input-konsentrasi').value || '',
                    tahun_ajaran: document.getElementById('input-tapel').value,
                    alamat: document.getElementById('input-alamat').value,
                    provinsi: document.getElementById('input-provinsi').value || '',
                    kota: document.getElementById('input-kota').value || '',
                    kepala_sekolah: document.getElementById('input-kepsek').value,
                    jabatan_kepsek: document.getElementById('input-jabatan') ? document.getElementById('input-jabatan').value : '',
                    nip_kepsek: document.getElementById('input-nip').value,
                    nuptk_kepsek: document.getElementById('input-nuptk').value || '',
                    id_kepsek_mode: idKepsekMode,
                    tanggal_pengumuman: document.getElementById('input-tgl').value,
                    tanggal_skl2: document.getElementById('input-tgl-skl2').value || null,
                    nomor_surat_mode: nomorMode,
                    nomor_surat_suffix: document.getElementById('input-nomor-surat').value || '',
                    nomor_surat_statis: document.getElementById('input-nomor-surat-statis').value || '',
                    telepon: document.getElementById('input-telepon').value || '',
                    email: document.getElementById('input-email').value || '',
                    domain: rawDomain,
                    pengumuman: document.getElementById('input-pengumuman').value || ''
                };

                // Konfirmasi sebelum menyimpan
                const confirmSave = await Swal.fire({
                    title: 'Konfirmasi Simpan',
                    text: 'Setelah Data Disimpan, link dan token ini akan hangus (di-terminate) demi keamanan. Anda tidak akan bisa kembali ke form ini. Lanjutkan?',
                    icon: 'warning',
                    showCancelButton: true,
                    confirmButtonColor: '#6366f1',
                    cancelButtonColor: '#slate-500',
                    confirmButtonText: 'Ya, Simpan & Selesai',
                    cancelButtonText: 'Batal',
                    customClass: {
                        popup: 'swal-custom-popup bg-white dark:bg-[#0B0F19] border border-slate-100 dark:border-slate-800',
                        title: 'text-slate-800 dark:text-white',
                        htmlContainer: 'text-slate-600 dark:text-slate-400',
                        confirmButton: 'bg-indigo-600 hover:bg-indigo-700 text-white rounded-xl px-4 py-2 font-medium',
                        cancelButton: 'bg-slate-200 hover:bg-slate-300 dark:bg-slate-800 dark:hover:bg-slate-700 text-slate-800 dark:text-white rounded-xl px-4 py-2 font-medium'
                    }
                });

                if (!confirmSave.isConfirmed) return;

                const btn = document.getElementById('btn-submit');
                const btnContent = btn.innerHTML;
                btn.innerHTML = 'Menyimpan...'; 
                btn.disabled = true;

                try {
                    const res = await fetch(`/api/form-lembaga.php?token=${token}`, {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify(payload)
                    });
                    const data = await res.json();
                    
                    if (data.success) {
                        // Arahkan ke Single Page Sukses
                        window.location.href = '/form-sukses';
                    } else {
                        Swal.fire({
                            title: 'Gagal Menyimpan',
                            text: data.error || 'Terjadi kesalahan saat menyimpan data.',
                            icon: 'error',
                            confirmButtonColor: '#ef4444',
                            customClass: {
                                popup: 'swal-custom-popup',
                                title: 'swal-custom-title',
                                confirmButton: 'swal-custom-btn'
                            }
                        });
                    }
                } catch (err) {
                    Swal.fire({
                        title: 'Kesalahan Jaringan',
                        text: err.message,
                        icon: 'error',
                        confirmButtonColor: '#ef4444',
                        customClass: {
                            popup: 'swal-custom-popup',
                            title: 'swal-custom-title',
                            confirmButton: 'swal-custom-btn'
                        }
                    });
                } finally {
                    btn.innerHTML = btnContent;
                    btn.disabled = false;
                }
            });
        });
    </script>
