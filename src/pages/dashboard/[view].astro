            <div><label class="block text-xs font-bold text-slate-500 uppercase tracking-widest mb-1.5">Kelas <span class="text-rose-400">*</span></label><input type="text" id="siswa-kelas" required placeholder="XII IPA 1" class="w-full bg-[#0F1523] border border-slate-700 rounded-xl py-2.5 px-4 text-sm text-white focus:border-indigo-500 outline-none transition-all"></div>
