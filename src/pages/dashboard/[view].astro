            <div><label class="block text-xs font-bold text-slate-500 uppercase tracking-widest mb-1.5">Tanggal Lahir</label><input type="date" id="siswa-tanggal-lahir" class="w-full bg-[#0F1523] border border-slate-700 rounded-xl py-2.5 px-4 text-sm text-white focus:border-indigo-500 outline-none transition-all date-input"></div>
            <div class="md:col-span-2"><label class="block text-xs font-bold text-slate-500 uppercase tracking-widest mb-1.5">Status Kelulusan</label><select id="siswa-status" class="w-full bg-[#0F1523] border border-slate-700 rounded-xl py-2.5 px-4 text-sm text-white focus:border-indigo-500 outline-none"><option value="LULUS">LULUS</option><option value="TIDAK LULUS">TIDAK LULUS</option></select></div>
