      <div class="p-6 border-b border-slate-800 flex items-center justify-between flex-shrink-0"><h3 class="text-white font-bold text-lg font-outfit" id="modal-siswa-title">Tambah Siswa</h3><button id="modal-siswa-close" class="text-slate-400 hover:text-white"><svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg></button></div>
