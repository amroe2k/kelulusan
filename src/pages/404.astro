---
import BaseLayout from '../layouts/BaseLayout.astro';
import '../styles/global.css';
---

<BaseLayout title="404 - Halaman Tidak Ditemukan">
  <!-- Modern Background Blobs -->
  <div class="fixed inset-0 overflow-hidden pointer-events-none z-0 bg-slate-50 dark:bg-[#0a0a12] transition-colors duration-500">
    <div class="absolute top-[-10%] left-[-10%] w-[40rem] h-[40rem] bg-indigo-600/10 dark:bg-indigo-600/20 rounded-full mix-blend-screen filter blur-[120px] animate-pulse-slow"></div>
    <div class="absolute bottom-[-10%] right-[-10%] w-[45rem] h-[45rem] bg-purple-600/10 dark:bg-purple-600/20 rounded-full mix-blend-screen filter blur-[120px] animate-pulse-slow" style="animation-delay:-2s;"></div>
    <div class="absolute top-[30%] right-[20%] w-80 h-80 bg-emerald-500/5 dark:bg-emerald-500/10 rounded-full mix-blend-screen filter blur-[100px] animate-pulse-slow" style="animation-delay:-4s;"></div>
  </div>

  <main class="relative z-10 min-h-screen flex flex-col items-center justify-center p-4">
    <div class="w-full max-w-lg text-center">
      <div class="glass-card p-10 md:p-16 relative overflow-hidden group">
        <!-- Decoration inside card -->
        <div class="absolute -top-20 -right-20 w-64 h-64 bg-indigo-500/10 dark:bg-indigo-500/20 rounded-full blur-3xl group-hover:scale-125 transition-transform duration-700"></div>
        <div class="absolute -bottom-20 -left-20 w-64 h-64 bg-purple-500/10 dark:bg-purple-500/20 rounded-full blur-3xl group-hover:scale-125 transition-transform duration-700"></div>

        <div class="relative z-10 space-y-8">
          <!-- Animated 404 Text -->
          <div class="relative inline-block">
            <h1 class="text-8xl md:text-9xl font-black tracking-tighter gradient-text animate-bounce-slow">
              404
            </h1>
            <div class="absolute -bottom-2 left-1/2 -translate-x-1/2 w-1/2 h-2 bg-indigo-500/20 blur-xl rounded-full"></div>
          </div>

          <div class="space-y-3">
            <h2 class="text-2xl md:text-3xl font-black text-slate-900 dark:text-white tracking-tight">
              Ups! Halaman Terpental
            </h2>
            <p class="text-slate-500 dark:text-slate-400 font-medium text-sm md:text-base leading-relaxed">
              Maaf, halaman yang Anda cari mungkin telah pindah, dihapus, atau memang tidak pernah ada di sini.
            </p>
          </div>

          <div class="pt-4">
            <a href="/" class="btn-primary inline-flex items-center gap-3 !py-4 !px-8 !rounded-2xl group shadow-indigo-500/20">
              <svg class="w-5 h-5 group-hover:-translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M10 19l-7-7m0 0l7-7m-7 7h18"/>
              </svg>
              <span class="font-bold tracking-tight">Kembali ke Beranda</span>
            </a>
          </div>
        </div>
      </div>

      <!-- Footer Info -->
      <p class="mt-8 text-slate-400 dark:text-slate-600 text-[10px] font-bold uppercase tracking-[0.3em] animate-fade-in">
        &copy; {new Date().getFullYear()} Siswa Digital Portal &bull; Errare Humanum Est
      </p>
    </div>
  </main>

  <style>
    @keyframes bounce-slow {
      0%, 100% { transform: translateY(0); }
      50% { transform: translateY(-10px); }
    }
    .animate-bounce-slow {
      animation: bounce-slow 4s ease-in-out infinite;
    }
    .perspective-1000 {
      perspective: 1000px;
    }
  </style>
</BaseLayout>
