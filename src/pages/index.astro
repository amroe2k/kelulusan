  .signature-box .role { font-size:${isSklNilai ? '14px' : '15px'}; font-weight:600; color:#1e293b; margin-bottom:10px; }
  .signature-box .name { font-size:${isSklNilai ? '14px' : '16px'}; font-weight:800; color:#0f172a; text-transform:uppercase; margin-top:5px; border-bottom:2px solid #0f172a; display:inline-block; padding-bottom:2px; }
  .signature-box .nip { font-size:${isSklNilai ? '12px' : '13px'}; color:#64748b; margin-top:4px; }
  .footer-note { position:absolute; bottom:30px; left:56px; right:36px; font-size:11px; color:#94a3b8; text-align:center; padding-top:10px; border-top:1px solid #f1f5f9; font-style:italic; z-index:1; }
  .page2-footer { display:none; }
  .page-break-section { margin-top:30px; }
  .page2-header { display:none; align-items:center; gap:20px; border-bottom:5px double #0f172a; padding-bottom:10px; margin-bottom:20px; }
  /* SKL2: halaman 2 */
  .skl2-sig-page { margin-top:20px; border-top:2px dashed #cbd5e1; padding-top:16px; position:relative; z-index:1; }
  .skl2-p2-kop { display:none; margin-bottom:20px; }
  @media print {
    * { -webkit-print-color-adjust: exact !important; print-color-adjust: exact !important; }
    @page { size:210mm 330mm; margin:10mm; }
    html, body { width:210mm; min-height:auto; overflow:visible; }
    .page { padding:0; min-height:0; overflow:visible; position:static; }
