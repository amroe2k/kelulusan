---
import BaseLayout from '../layouts/BaseLayout.astro';
import '../styles/global.css';
---

<BaseLayout title="Portal Hasil Kelulusan Siswa">
  
  <!-- Modern Background Blobs -->
  <div class="fixed inset-0 overflow-hidden pointer-events-none z-0 bg-slate-50 dark:bg-[#0a0a12] transition-colors duration-500">
    <div class="absolute top-[-10%] left-[-10%] w-[40rem] h-[40rem] bg-indigo-600/10 dark:bg-indigo-600/20 rounded-full mix-blend-screen filter blur-[120px] animate-pulse-slow"></div>
    <div class="absolute bottom-[-10%] right-[-10%] w-[45rem] h-[45rem] bg-purple-600/10 dark:bg-purple-600/20 rounded-full mix-blend-screen filter blur-[120px] animate-pulse-slow" style="animation-delay:-2s;"></div>
  </div>

  <!-- Confetti canvas -->
  <canvas id="confetti-canvas" class="fixed inset-0 pointer-events-none z-50"></canvas>

  <div class="relative z-10 min-h-screen flex flex-col font-poppins">
    
    <!-- Premium Navbar -->
    <nav class="sticky top-0 z-30 bg-white/40 dark:bg-[#0a0a12]/60 backdrop-blur-xl border-b border-slate-200 dark:border-white/5">
      <div class="max-w-6xl mx-auto px-6 py-4 flex justify-between items-center">
        <div class="flex items-center gap-3 group">
          <div class="w-10 h-10 rounded-xl flex items-center justify-center shadow-lg shadow-indigo-500/20 bg-gradient-to-br from-indigo-500 to-indigo-700 rotate-3 group-hover:rotate-0 transition-transform duration-500">
            <svg class="w-5 h-5 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 14l9-5-9-5-9 5 9 5z"/></svg>
          </div>
          <span class="font-black text-slate-900 dark:text-white text-lg font-outfit tracking-tight">PortalSiswa</span>
        </div>
        <div class="flex items-center gap-4">
          <a href="/" class="hidden sm:flex items-center gap-2 text-xs font-black uppercase tracking-widest text-slate-500 hover:text-indigo-500 transition-all">
            Cek NISN Lain
          </a>
          <div class="w-px h-4 bg-slate-300 dark:bg-white/10 hidden sm:block"></div>
          <button id="btn-logout" class="flex items-center gap-2 text-xs font-black uppercase tracking-widest text-rose-500 hover:bg-rose-500/10 px-4 py-2 rounded-xl transition-all border border-transparent hover:border-rose-500/20">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1"/></svg>
            Keluar
          </button>
        </div>
      </div>
    </nav>

    <main class="flex-1 max-w-5xl mx-auto w-full px-6 py-10 space-y-8">

      <!-- ── LOADING STATE ── -->
      <div id="loading-state" class="flex flex-col items-center justify-center py-32 animate-pulse">
        <div class="relative w-16 h-16 mb-6">
          <div class="absolute inset-0 border-4 border-indigo-500/20 rounded-full"></div>
          <div class="absolute inset-0 border-4 border-indigo-500 border-t-transparent rounded-full animate-spin"></div>
        </div>
        <p class="text-indigo-500 dark:text-indigo-400 font-black text-xs uppercase tracking-[0.3em]">Otentikasi Identitas Siswa...</p>
      </div>

      <!-- ── NOT FOUND ── -->
      <div id="not-found" class="hidden animate-fade-in text-center py-24 glass-card max-w-lg mx-auto p-12">
        <div class="w-24 h-24 rounded-3xl bg-slate-100 dark:bg-white/5 flex items-center justify-center text-slate-400 mx-auto mb-8 border border-slate-200 dark:border-white/10 shadow-inner">
           <svg class="w-12 h-12" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/></svg>
        </div>
        <h2 class="text-2xl font-black font-outfit text-slate-900 dark:text-white mb-3">Data Belum Diunggah</h2>
        <p class="text-sm text-slate-500 font-medium mb-10 leading-relaxed">Sistem belum menemukan data kelulusan yang terkait dengan akun Anda. Silakan hubungi bagian kurikulum atau administrator sekolah.</p>
        <a href="/login" class="btn-primary !px-10 !py-4 !rounded-2xl !text-xs !font-black !uppercase !tracking-widest">Kembali ke Login</a>
      </div>

      <!-- ── MAIN CONTENT ── -->
      <div id="main-content" class="hidden space-y-8 animate-fade-in">

        <!-- Welcome & Profile Grid -->
        <div class="grid grid-cols-1 lg:grid-cols-12 gap-8 items-stretch">
          
          <!-- Identity Card -->
          <div class="lg:col-span-7 glass-card p-8 flex flex-col md:flex-row items-center gap-8 relative overflow-hidden group">
             <div class="absolute -top-12 -left-12 w-32 h-32 bg-indigo-500/5 rounded-full blur-3xl group-hover:scale-150 transition-transform duration-1000"></div>
             <!-- Avatar -->
             <div class="flex-shrink-0 flex items-center justify-center w-28 h-28 rounded-[2.5rem] text-5xl font-black text-white shadow-2xl shadow-indigo-500/30 bg-gradient-to-br from-indigo-500 to-indigo-700 z-10" id="profile-avatar">-</div>
             <!-- Info -->
             <div class="flex-1 text-center md:text-left z-10">
               <p class="text-[10px] font-black text-indigo-500 uppercase tracking-[0.3em] mb-2">Siswa Terverifikasi</p>
               <h1 class="text-3xl md:text-4xl font-black text-slate-900 dark:text-white mb-4 font-outfit tracking-tight leading-tight" id="s-nama">-</h1>
               <div class="flex flex-wrap justify-center md:justify-start gap-4">
                  <div class="px-4 py-2 rounded-xl bg-slate-100 dark:bg-white/5 border border-slate-200 dark:border-white/10 flex items-center gap-2">
                    <svg class="w-4 h-4 text-slate-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 20l4-16m2 16l4-16M6 9h14M4 15h14"/></svg>
                    <span class="text-xs font-bold text-slate-600 dark:text-slate-300" id="s-nisn">-</span>
                  </div>
                  <div class="px-4 py-2 rounded-xl bg-slate-100 dark:bg-white/5 border border-slate-200 dark:border-white/10 flex items-center gap-2">
                    <svg class="w-4 h-4 text-slate-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"/></svg>
                    <span class="text-xs font-bold text-slate-600 dark:text-slate-300" id="s-kelas">-</span>
                  </div>
               </div>
             </div>
          </div>

          <!-- Status Card -->
          <div class="lg:col-span-5 glass-card p-8 flex flex-col items-center justify-center text-center relative overflow-hidden" id="status-banner">
             <div class="absolute inset-0 bg-gradient-to-br opacity-5" id="status-bg-overlay"></div>
             <p class="text-[10px] font-black text-slate-500 uppercase tracking-[0.2em] mb-4 relative z-10">Keputusan Akhir</p>
             <div id="status-display" class="text-5xl font-black font-outfit tracking-[0.1em] mb-4 relative z-10">—</div>
             <div class="px-4 py-1 rounded-full bg-slate-900/5 dark:bg-white/5 text-[9px] font-black uppercase tracking-widest text-slate-400 relative z-10" id="s-tapel">-</div>
          </div>
        </div>

        <!-- Stats Row -->
        <div id="dashboard-stats" class="grid grid-cols-1 md:grid-cols-3 gap-6">
          <div class="premium-stat-card bg-white dark:bg-white/5 border-slate-200 dark:border-white/10 shadow-sm flex items-center gap-6 p-8 rounded-[2.5rem]">
            <div class="w-14 h-14 rounded-2xl bg-indigo-500/10 flex items-center justify-center text-indigo-500"><svg class="w-7 h-7" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6"/></svg></div>
            <div><p class="text-[10px] font-black text-slate-400 uppercase tracking-widest">Rata-rata</p><p class="text-3xl font-black font-outfit text-slate-900 dark:text-white" id="s-rata">0.00</p></div>
          </div>
          <div class="premium-stat-card bg-white dark:bg-white/5 border-slate-200 dark:border-white/10 shadow-sm flex items-center gap-6 p-8 rounded-[2.5rem]">
            <div class="w-14 h-14 rounded-2xl bg-emerald-500/10 flex items-center justify-center text-emerald-500"><svg class="w-7 h-7" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 3v4M3 5h4M6 17v4m-2-2h4m5-16l2.286 6.857L21 12l-7.714 2.143L11 21l-2.286-6.857L1 12l7.714-2.143L11 3z"/></svg></div>
            <div><p class="text-[10px] font-black text-slate-400 uppercase tracking-widest">Tertinggi</p><p class="text-3xl font-black font-outfit text-emerald-500" id="s-max">0</p></div>
          </div>
          <div class="premium-stat-card bg-white dark:bg-white/5 border-slate-200 dark:border-white/10 shadow-sm flex items-center gap-6 p-8 rounded-[2.5rem]">
            <div class="w-14 h-14 rounded-2xl bg-purple-500/10 flex items-center justify-center text-purple-500"><svg class="w-7 h-7" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.246.477 4 1.253m0-13C12.754 5.477 14.342 5 16.1 5s3.332.477 4.5 1.253v13C19.342 18.477 17.754 18 16.1 18c-1.746 0-3.332.477-4.5 1.253"/></svg></div>
            <div><p class="text-[10px] font-black text-slate-400 uppercase tracking-widest">Mapel</p><p class="text-3xl font-black font-outfit text-slate-900 dark:text-white" id="s-mapel-count">0</p></div>
          </div>
        </div>

        <!-- Rincian Nilai -->
        <div id="dashboard-nilai" class="glass-card overflow-hidden">
          <div class="p-8 border-b border-slate-200 dark:border-white/5 flex items-center justify-between">
            <h2 class="text-xl font-black font-outfit text-slate-900 dark:text-white">Transkrip Nilai Akademik</h2>
            <div class="flex items-center gap-2 px-4 py-1.5 rounded-xl bg-slate-100 dark:bg-white/5 border border-slate-200 dark:border-white/10">
               <span class="w-2 h-2 rounded-full bg-indigo-500 animate-pulse"></span>
               <span class="text-[10px] font-black text-slate-500 uppercase tracking-widest" id="s-tahun">-</span>
            </div>
          </div>
          <div class="overflow-x-auto custom-scrollbar">
            <table class="w-full text-left">
              <thead class="bg-slate-50 dark:bg-white/5 border-b border-slate-200 dark:border-white/5">
                <tr>
                  <th class="px-8 py-5 text-[10px] font-black uppercase tracking-widest text-slate-400">No</th>
                  <th class="px-8 py-5 text-[10px] font-black uppercase tracking-widest text-slate-400">Mata Pelajaran</th>
                  <th class="px-8 py-5 text-[10px] font-black uppercase tracking-widest text-slate-400 text-center">Skor Akhir</th>
                  <th class="px-8 py-5 text-[10px] font-black uppercase tracking-widest text-slate-400 text-center">Predikat</th>
                </tr>
              </thead>
              <tbody id="nilai-tbody" class="divide-y divide-slate-100 dark:divide-white/5">
                <!-- JS Driven -->
              </tbody>
            </table>
          </div>
        </div>

        <!-- Footer Actions -->
        <div class="flex flex-col sm:flex-row gap-4 items-center justify-center pt-8 pb-12">
          <!-- Tombol PDF Pre-generated (muncul jika ada pdf_path) -->
          <a id="btn-preview-skl" href="#" target="_blank" class="hidden w-full sm:w-auto btn-success !px-10 !py-5 !rounded-[2rem] !text-sm !font-black !uppercase !tracking-widest flex items-center justify-center gap-3 group shadow-2xl shadow-emerald-500/20">
            <svg class="w-6 h-6 group-hover:scale-110 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"/></svg>
            Preview SKL
          </a>
          <a id="btn-download-skl" href="#" download class="hidden w-full sm:w-auto px-10 py-5 rounded-[2rem] bg-emerald-600 hover:bg-emerald-500 text-white text-sm font-black uppercase tracking-widest flex items-center justify-center gap-3 group shadow-2xl shadow-emerald-500/20 transition-all">
            <svg class="w-6 h-6 group-hover:-translate-y-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4"/></svg>
            Unduh SKL
          </a>
          <!-- Fallback: generate client-side (muncul jika belum ada PDF) -->
          <button id="btn-pdf" class="hidden w-full sm:w-auto btn-success !px-12 !py-5 !rounded-[2rem] !text-sm !font-black !uppercase !tracking-widest flex items-center justify-center gap-3 group shadow-2xl shadow-emerald-500/20">
            <svg class="w-6 h-6 group-hover:-translate-y-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4"/></svg>
            Generate SKL
          </button>
          <a href="/" class="w-full sm:w-auto px-10 py-5 rounded-[2rem] bg-slate-100 dark:bg-white/5 border border-slate-200 dark:border-white/10 text-slate-600 dark:text-slate-300 text-sm font-black uppercase tracking-widest hover:text-indigo-500 transition-all flex items-center justify-center gap-2">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/></svg>
            Cek NISN Lain
          </a>
        </div>
      </div>
    </main>
  </div>

  <!-- PDF iframe (hidden, identical to admin) -->
  <iframe id="skl-iframe" style="position:absolute;top:0;left:-9999px;width:794px;height:1123px;border:none;" title="SKL Preview"></iframe>


  <style>
    .custom-scrollbar::-webkit-scrollbar { width: 5px; height: 5px; }
    .custom-scrollbar::-webkit-scrollbar-track { background: transparent; }
    .custom-scrollbar::-webkit-scrollbar-thumb { background: rgba(99, 102, 241, 0.15); border-radius: 20px; }
    .custom-scrollbar::-webkit-scrollbar-thumb:hover { background: rgba(99, 102, 241, 0.3); }

    .premium-stat-card { @apply transition-all duration-300 hover:scale-105 border; }

    @keyframes fade-in { from { opacity: 0; transform: translateY(20px); } to { opacity: 1; transform: translateY(0); } }
    .animate-fade-in { animation: fade-in 0.8s cubic-bezier(0.16, 1, 0.3, 1) forwards; }
  </style>

  <script is:inline src="https://cdnjs.cloudflare.com/ajax/libs/html2canvas/1.4.1/html2canvas.min.js"></script>
  <script is:inline src="https://cdnjs.cloudflare.com/ajax/libs/jspdf/2.5.1/jspdf.umd.min.js"></script>

  <script is:inline>
  const $ = id => document.getElementById(id);

  function predikat(n) {
    if (n >= 90) return { l:'A (Excellent)', c:'text-emerald-500' };
    if (n >= 80) return { l:'B (Good)',      c:'text-indigo-500' };
    if (n >= 70) return { l:'C (Fair)',      c:'text-amber-500' };
    return           { l:'D (Poor)',      c:'text-rose-500' };
  }

  function launchConfetti() {
    const canvas = $('confetti-canvas');
    const ctx    = canvas.getContext('2d');
    canvas.width  = window.innerWidth;
    canvas.height = window.innerHeight;
    const pieces = Array.from({length:180},()=>({
      x: Math.random()*canvas.width, y: Math.random()*canvas.height-canvas.height,
      size: Math.random()*10+5, speed: Math.random()*4+2,
      color: ['#6366f1','#22c55e','#f59e0b','#ec4899','#06b6d4','#a78bfa'][Math.floor(Math.random()*6)],
      angle: Math.random()*360, spin: (Math.random()-0.5)*10,
    }));
    let frame = 0;
    function draw() {
      ctx.clearRect(0,0,canvas.width,canvas.height);
      pieces.forEach(p => {
        ctx.save(); ctx.translate(p.x,p.y); ctx.rotate(p.angle*Math.PI/180);
        ctx.fillStyle = p.color; ctx.fillRect(-p.size/2,-p.size/2,p.size,p.size);
        ctx.restore();
        p.y += p.speed; p.angle += p.spin;
        if (p.y > canvas.height) { p.y = -20; p.x = Math.random()*canvas.width; }
      });
      if (++frame < 400) requestAnimationFrame(draw);
      else ctx.clearRect(0,0,canvas.width,canvas.height);
    }
    draw();
  }

  document.addEventListener('DOMContentLoaded', async () => {
    const auth = JSON.parse(sessionStorage.getItem('auth')||'null');
    if (!auth || auth.role !== 'siswa') { window.location.href = '/login'; return; }

    $('btn-logout').onclick = () => {
      showConfirm('Anda ingin mengakhiri sesi portal siswa?', () => {
        sessionStorage.removeItem('auth'); window.location.href = '/login'; 
      });
    };

    let data, siswa;
    try {
      const r = await fetch('/data.json', { cache: 'no-store' });
      data = await r.json();
      siswa = auth.nisn_hash ? data.siswa[auth.nisn_hash] : null;
    } catch {
       showToast('Kegagalan sinkronisasi data.', 'error');
    }

    $('loading-state').classList.add('hidden');

    if (!siswa) { $('not-found').classList.remove('hidden'); return; }

    $('main-content').classList.remove('hidden');

    // Profile
    $('profile-avatar').textContent = siswa.nama.charAt(0).toUpperCase();
    $('s-nama').textContent  = siswa.nama;
    $('s-nisn').textContent  = 'NISN: ' + siswa.nisn_display;
    $('s-kelas').textContent = 'KELAS: ' + siswa.kelas;
    $('s-tapel').textContent = `Tahun Pelajaran ${data._meta.tahun_ajaran}`;
    $('s-tahun').textContent = data._meta.tahun_ajaran;
    
    // Toggle SKL1 (Tanpa Nilai) vs SKL2 (Dengan Nilai)
    if (data._meta.jenis_skl === 'skl1') {
      $('dashboard-stats').style.display = 'none';
      $('dashboard-nilai').style.display = 'none';
      $('pdf-rincian-text').style.display = 'none';
      $('pdf-tabel-nilai').style.display = 'none';
    }

    // Status
    const isLulus = siswa.status === 'LULUS';
    const statusDisplay = $('status-display');
    const statusBanner = $('status-banner');
    const statusIcon = $('status-icon-container');
    const statusOverlay = $('status-bg-overlay');
    
    statusDisplay.textContent = siswa.status;
    
    if (isLulus) {
      statusDisplay.className = 'text-5xl font-black font-outfit tracking-[0.05em] mb-6 relative z-10 text-emerald-500 drop-shadow-sm';
      statusBanner.classList.add('border-emerald-500/20');
      statusIcon.className = 'w-20 h-20 rounded-full flex items-center justify-center mb-6 relative z-10 shadow-xl shadow-emerald-500/20 bg-emerald-500 text-white animate-bounce-slow';
      statusIcon.innerHTML = '<svg class="w-10 h-10" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7"/></svg>';
      statusOverlay.classList.replace('from-transparent', 'from-emerald-500');
      setTimeout(launchConfetti, 800);
    } else {
      statusDisplay.className = 'text-5xl font-black font-outfit tracking-[0.05em] mb-6 relative z-10 text-rose-500 drop-shadow-sm';
      statusBanner.classList.add('border-rose-500/20');
      statusIcon.className = 'w-20 h-20 rounded-full flex items-center justify-center mb-6 relative z-10 shadow-xl shadow-rose-500/20 bg-rose-500 text-white';
      statusIcon.innerHTML = '<svg class="w-10 h-10" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M6 18L18 6M6 6l12 12"/></svg>';
      statusOverlay.classList.replace('from-transparent', 'from-rose-500');
    }

    // Stats
    const nilaiArr = siswa.nilai || [];
    const max = nilaiArr.length ? Math.max(...nilaiArr.map(n=>n.nilai)) : 0;
    $('s-rata').textContent        = siswa.rata_rata ? siswa.rata_rata.toFixed(2) : '0.00';
    $('s-max').textContent         = max || '0';
    $('s-mapel-count').textContent = nilaiArr.length;

    // Nilai table
    const tbody = $('nilai-tbody');
    tbody.innerHTML = '';
    nilaiArr.forEach((item, i) => {
      const p = predikat(item.nilai);
      const tr = document.createElement('tr');
      tr.className = 'group transition-colors hover:bg-slate-50 dark:hover:bg-white/5';
      tr.innerHTML = `
        <td class="px-8 py-5 text-slate-400 font-bold text-xs">${i+1}</td>
        <td class="px-8 py-5">
           <p class="text-slate-900 dark:text-white font-bold text-sm">${item.mapel}</p>
           <p class="text-[9px] font-black uppercase text-slate-400 tracking-tighter">Subjek Akademik</p>
        </td>
        <td class="px-8 py-5 text-center font-black text-lg font-outfit ${p.c}">${item.nilai}</td>
        <td class="px-8 py-5 text-center">
           <span class="px-3 py-1 rounded-lg bg-slate-100 dark:bg-white/5 border border-slate-200 dark:border-white/5 text-[10px] font-black uppercase tracking-widest ${p.c}">${p.l.split(' ')[0]}</span>
        </td>`;
      tbody.appendChild(tr);
    });

    // Setup tombol SKL: pre-generated PDF vs client-side fallback
    const pdfPath = siswa.pdf_path || null;
    if (pdfPath) {
      // Ada PDF pre-generated
      $('btn-preview-skl').href  = pdfPath;
      $('btn-download-skl').href = pdfPath;
      $('btn-download-skl').setAttribute('download', `SKL_${siswa.nama.replace(/\s+/g,'_')}.pdf`);
      $('btn-preview-skl').classList.remove('hidden');
      $('btn-download-skl').classList.remove('hidden');
    } else {
      // Fallback: generate client-side
      $('btn-pdf').classList.remove('hidden');
    }

    // PDF (client-side fallback)
    $('btn-pdf').addEventListener('click', async () => {
      const btn = $('btn-pdf');
      const orig = btn.innerHTML;
      btn.disabled = true; 
      btn.innerHTML = '<svg class="animate-spin h-5 w-5 mr-3" viewBox="0 0 24 24" fill="none"><circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"/><path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"/></svg> <span class="font-black uppercase tracking-widest text-xs">Menyiapkan Dokumen...</span>';
      
      try {
        const m = data._meta;

        // Build full HTML document (identical to admin)
        const htmlDoc = buildSklHtml(m, siswa, nilaiArr, m.jenis_skl || 'skl2');

        // Write to hidden iframe
        const iframe = document.getElementById('skl-iframe');
        iframe.contentDocument.open();
        iframe.contentDocument.write(htmlDoc);
        iframe.contentDocument.close();

        // Wait for fonts + images inside iframe to load
        await new Promise(resolve => {
          iframe.onload = resolve;
          if (iframe.contentDocument.readyState === 'complete') resolve();
        });
        await new Promise(r => setTimeout(r, 800)); // extra wait for Google Fonts

        // Render canvas from iframe body
        const iframeBody = iframe.contentDocument.body;
        const canvas = await html2canvas(iframeBody, { scale: 2, useCORS: true, logging: false, backgroundColor: '#ffffff', allowTaint: false });

        const { jsPDF } = window.jspdf;
        const pdf = new jsPDF('p','mm','a4');
        const pw = pdf.internal.pageSize.getWidth();
        const ph = pdf.internal.pageSize.getHeight();
        const imgH = (canvas.height * pw) / canvas.width;
        if (imgH > ph) {
          let yPos = 0;
          const pageH = canvas.width * (ph / pw);
          while (yPos < canvas.height) {
            const portion = document.createElement('canvas');
            portion.width = canvas.width;
            portion.height = Math.min(pageH, canvas.height - yPos);
            portion.getContext('2d').drawImage(canvas, 0, yPos, canvas.width, portion.height, 0, 0, canvas.width, portion.height);
            if (yPos > 0) pdf.addPage();
            pdf.addImage(portion.toDataURL('image/png'), 'PNG', 0, 0, pw, portion.height*pw/canvas.width);
            yPos += pageH;
          }
        } else {
          pdf.addImage(canvas.toDataURL('image/png'), 'PNG', 0, 0, pw, imgH);
        }
        const prefix = m.jenis_skl === 'skl1' ? 'SKL1' : 'SKL2';
        pdf.save(`${prefix}-${siswa.nama.replace(/\s+/g,'_')}-${(siswa.nisn_display||siswa.nisn||'0000000000').replace(/\*/g,'x')}.pdf`);
        showToast('Dokumen SKL berhasil diterbitkan.', 'success');
      } catch (err) {
        console.error(err); showToast('Gagal memproses dokumen PDF.', 'error');
      } finally {
        btn.innerHTML = orig; btn.disabled = false;
      }
    });
  });

  // ─── buildSklHtml: Full HTML document, identical to admin buildSklPreviewHtml ───
  function buildSklHtml(meta, siswaData, nilaiData, type) {
    const isSklNilai = (type !== 'skl1');
    const bulan = ['Januari','Februari','Maret','April','Mei','Juni','Juli','Agustus','September','Oktober','November','Desember'];
    const fmt = d => { if(!d) return '-'; if(typeof d==='string' && !/^\d{4}-\d{2}-\d{2}$/.test(d.trim())) return d; const parts = typeof d==='string' ? d.split('-') : null; if(parts&&parts.length===3) return `${parseInt(parts[2])} ${bulan[parseInt(parts[1])-1]} ${parts[0]}`; const dt=new Date(d); return `${dt.getDate()} ${bulan[dt.getMonth()]} ${dt.getFullYear()}`; };
    const now = new Date();
    const siswa = siswaData;
    const nilai = nilaiData && nilaiData.length ? nilaiData : [];
    const rataRata = nilai.length ? (nilai.reduce((s,n) => s+n.nilai, 0)/nilai.length).toFixed(2) : '-';
    const sklNum = String(Math.floor(Math.random()*900+100)).padStart(3,'0');
    const nomorSurat = meta.nomor_surat_suffix ? `${sklNum}${meta.nomor_surat_suffix}` : `${sklNum}/${meta.npsn||'SKL'}/${now.getFullYear()}`;
    const isSmk = (meta.jenjang||'').toUpperCase() === 'SMK';
    const smkKompetensi = siswa.kompetensi_keahlian || meta.kompetensi_keahlian || '';
    const smkHeaderLine = isSmk && smkKompetensi ? `<p style="margin-top:3px;font-weight:700;color:#4f46e5;">Kompetensi Keahlian: ${smkKompetensi}</p>` : '';
    const tglPengumuman = isSklNilai
      ? (meta.tanggal_skl2 ? fmt(meta.tanggal_skl2) : fmt(meta.tanggal_pengumuman||now.toISOString().split('T')[0]))
      : (meta.tanggal_pengumuman ? fmt(meta.tanggal_pengumuman) : fmt(now.toISOString().split('T')[0]));
    const logoHtml = meta.logo ? `<img src="${meta.logo}" style="height:90px;width:90px;object-fit:contain;" crossorigin="anonymous" />` : `<div style="width:90px;height:90px;border:2px solid #ddd;border-radius:12px;display:flex;align-items:center;justify-content:center;font-size:10px;color:#999;background:#fafafa;">LOGO</div>`;
    const stempelHtml = meta.stempel ? `<img src="${meta.stempel}" crossorigin="anonymous" style="position:absolute;top:15px;left:-10px;width:140px;height:140px;object-fit:contain;opacity:0.6;pointer-events:none;" />` : '';
    const ttdHtml = meta.ttd ? `<img src="${meta.ttd}" crossorigin="anonymous" style="height:70px;margin:0 auto 4px auto;display:block;" />` : `<div style="height:70px;"></div>`;
    const nilaiRows = nilai.map((n,i) => `<tr><td style="padding:8px 10px;text-align:center;color:#666;font-size:11px;">${i+1}</td><td style="padding:8px 10px;color:#333;">${n.mapel}</td><td style="padding:8px 10px;text-align:center;font-weight:700;color:#111;">${n.nilai}</td></tr>`).join('');
    const kota = meta.kota || (meta.alamat ? (meta.alamat.split(',')[1] || meta.alamat.split(',')[0]).trim() : '........');
    const sklBody = isSklNilai ? `
      <p class="intro-text">Kepala <strong>${meta.sekolah||'Sekolah'}</strong> menerangkan bahwa berdasarkan hasil Rapat Pleno Dewan Guru tentang Penetapan Kelulusan Peserta Didik, dinyatakan bahwa:</p>
      <table class="student-data">
        <tr><td>Nama Lengkap</td><td>:</td><td>${siswa.nama}</td></tr>
        <tr><td>NISN</td><td>:</td><td>${siswa.nisn_display||siswa.nisn||'-'}</td></tr>
        <tr><td>Tempat, Tanggal Lahir</td><td>:</td><td>${siswa.tempat_lahir||'-'}, ${fmt(siswa.tanggal_lahir)}</td></tr>
        <tr><td>Kelas</td><td>:</td><td>${siswa.kelas}</td></tr>
        ${isSmk&&smkKompetensi?`<tr><td>Kompetensi Keahlian</td><td>:</td><td>${smkKompetensi}</td></tr>`:''}
        <tr><td>Tahun Pelajaran</td><td>:</td><td>${meta.tahun_ajaran||'-'}</td></tr>
      </table>
      <p class="intro-text">Dinyatakan <strong>${siswa.status||'LULUS'}</strong> dari satuan pendidikan dengan rincian nilai sebagai berikut:</p>
      <div class="scores-container"><table class="scores-table"><thead><tr><th style="width:50px;text-align:center;">No</th><th>Mata Pelajaran</th><th style="width:100px;text-align:center;">Nilai</th></tr></thead><tbody>${nilaiRows}<tr class="avg-row"><td colspan="2" style="text-align:right;padding-right:20px;">RATA-RATA NILAI</td><td style="text-align:center;">${rataRata}</td></tr></tbody></table></div>
      <div class="result-status"><span class="badge ${siswa.status==='TIDAK LULUS'?'badge-tidak':'badge-lulus'}">${siswa.status||'LULUS'}</span></div>
      <p class="intro-text" style="margin-top:40px;">Demikian pengumuman ini disampaikan untuk diketahui dan dipergunakan sebagaimana mestinya.</p>
    ` : `
      <p class="intro-text">Kepala <strong>${meta.sekolah||'Sekolah'}</strong> menerangkan bahwa berdasarkan hasil Rapat Pleno Dewan Guru, dinyatakan bahwa:</p>
      <table class="student-data">
        <tr><td>Nama Lengkap</td><td>:</td><td>${siswa.nama}</td></tr>
        <tr><td>NISN</td><td>:</td><td>${siswa.nisn_display||siswa.nisn||'-'}</td></tr>
        <tr><td>Tempat, Tanggal Lahir</td><td>:</td><td>${siswa.tempat_lahir||'-'}, ${fmt(siswa.tanggal_lahir)}</td></tr>
        <tr><td>Kelas</td><td>:</td><td>${siswa.kelas}</td></tr>
        ${isSmk&&smkKompetensi?`<tr><td>Kompetensi Keahlian</td><td>:</td><td>${smkKompetensi}</td></tr>`:''}
        <tr><td>Tahun Pelajaran</td><td>:</td><td>${meta.tahun_ajaran||'-'}</td></tr>
      </table>
      <div class="result-status" style="margin:30px 0 20px;"><span class="badge ${siswa.status==='TIDAK LULUS'?'badge-tidak':'badge-lulus'}">${siswa.status||'LULUS'}</span></div>
      <p class="intro-text" style="text-align:center;">Yang bersangkutan dinyatakan <strong>${siswa.status||'LULUS'}</strong> dari satuan pendidikan ${meta.sekolah||\"\"}.<br><em style="font-size:10px;color:#64748b;">Rincian nilai akan tercantum dalam SKL resmi yang diterbitkan pada tanggal ${meta.tanggal_skl2 ? fmt(meta.tanggal_skl2) : (meta.tanggal_skl2_display||'...')}</em></p>
      <p class="intro-text" style="margin-top:40px;">Demikian pengumuman ini disampaikan untuk diketahui dan dipergunakan sebagaimana mestinya.</p>
    `;
    return `<!DOCTYPE html>
<html lang="id"><head><meta charset="UTF-8">
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700;800&family=Outfit:wght@400;700&display=swap" rel="stylesheet">
<style>
  * { margin:0; padding:0; box-sizing:border-box; }
  html, body { overflow:hidden; }
  body { font-family:'Inter',sans-serif; background:#fff; width:794px; min-height:1123px; padding:20px; display:flex; justify-content:center; }
  .page { background:#fff; width:100%; min-height:1083px; padding:20px 50px 100px; position:relative; }
  .watermark { position:absolute; top:50%; left:50%; transform:translate(-50%,-50%) rotate(-30deg); font-size:100px; font-weight:900; color:rgba(0,0,0,0.02); text-transform:uppercase; white-space:nowrap; pointer-events:none; z-index:0; }
  .header { display:flex; align-items:center; gap:20px; border-bottom:3px solid #1e293b; padding-bottom:10px; margin-bottom:10px; position:relative; z-index:1; }
  .header-text { flex:1; text-align:center; }
  .header-text h2 { font-family:'Outfit',sans-serif; font-size:20px; font-weight:800; text-transform:uppercase; letter-spacing:1px; color:#0f172a; margin-bottom:4px; }
  .header-text p { font-size:10px; color:#475569; line-height:1.4; }
  .title-area { text-align:center; margin:10px 0; position:relative; z-index:1; }
  .title-area h3 { font-family:'Outfit',sans-serif; font-size:16px; font-weight:800; text-transform:uppercase; color:#0f172a; letter-spacing:3px; }
  .title-area .line { width:150px; height:3px; background:#0f172a; margin:6px auto; }
  .title-area p { font-size:11px; font-weight:600; color:#64748b; margin-top:5px; }
  .intro-text { font-size:12px; line-height:1.5; margin:8px 0; color:#334155; position:relative; z-index:1; }
  .student-data { border-collapse:collapse; width:100%; margin:8px 0; font-size:12px; position:relative; z-index:1; }
  .student-data td { padding:4px 0; vertical-align:top; }
  .student-data td:first-child { width:160px; color:#64748b; font-weight:500; }
  .student-data td:nth-child(2) { width:15px; text-align:center; color:#94a3b8; }
  .student-data td:last-child { font-weight:700; color:#0f172a; }
  .scores-container { margin:10px 0; position:relative; z-index:1; }
  .scores-table { border-collapse:collapse; width:100%; font-size:11px; border:1px solid #e2e8f0; }
  .scores-table th { background:#f8fafc; color:#64748b; font-weight:700; text-transform:uppercase; font-size:9px; letter-spacing:1px; padding:8px 10px; border-bottom:2px solid #e2e8f0; text-align:left; }
  .scores-table td { padding:5px 10px; border-bottom:1px solid #f1f5f9; }
  .scores-table .avg-row { background:#f8fafc; font-weight:800; font-size:12px; }
  .result-status { text-align:center; margin:10px 0; position:relative; z-index:1; }
  .badge { display:inline-block; padding:6px 30px; border-radius:12px; font-size:20px; font-weight:900; text-transform:uppercase; letter-spacing:4px; transform:rotate(-2deg); box-shadow:0 4px 10px rgba(0,0,0,0.1); }
  .badge-lulus { background:#ecfdf5; color:#059669; border:3px solid #10b981; }
  .badge-tidak { background:#fef2f2; color:#dc2626; border:3px solid #ef4444; }
  .signature-area { display:flex; justify-content:flex-end; margin-top:30px; position:relative; z-index:1; }
  .signature-box { text-align:center; position:relative; min-width:240px; }
  .signature-box .date { font-size:12px; color:#475569; margin-bottom:4px; }
  .signature-box .role { font-size:13px; font-weight:600; color:#1e293b; margin-bottom:10px; }
  .signature-box .name { font-size:14px; font-weight:800; color:#0f172a; text-transform:uppercase; margin-top:5px; border-bottom:2px solid #0f172a; display:inline-block; padding-bottom:2px; }
  .signature-box .nip { font-size:11px; color:#64748b; margin-top:4px; }
  .footer-note { position:absolute; bottom:30px; left:50px; right:50px; font-size:9px; color:#94a3b8; text-align:center; padding-top:10px; border-top:1px solid #f1f5f9; font-style:italic; z-index:1; }
</style></head><body>
  <div class="page">
    <div class="watermark">${meta.sekolah||'SKL'}</div>
    <div class="header">${logoHtml}<div class="header-text"><h2>${meta.sekolah||'NAMA SEKOLAH'}</h2><p style="margin-top:4px;font-weight:600;">NSS: ${meta.nss||'-'} | NPSN: ${meta.npsn||'-'}</p><p>${meta.alamat||'-'}</p>${(meta.telepon||meta.email) ? `<p style="margin-top:2px;">Telp: ${meta.telepon||'-'} | Email: ${meta.email||'-'}</p>` : ''}${smkHeaderLine}</div><div style="width:90px;height:90px;flex-shrink:0;"></div></div>
    <div class="title-area"><h3>SURAT KETERANGAN LULUS</h3><div class="line"></div><p>Nomor: ${nomorSurat}</p></div>
    ${sklBody}
    <div class="signature-area"><div class="signature-box">${stempelHtml}<p class="date">${kota}, ${tglPengumuman}</p><p class="role">Kepala Sekolah,</p><div style="margin:10px 0;">${ttdHtml}</div><p class="name">${meta.kepala_sekolah||'Kepala Sekolah'}</p><p class="nip">NIP. ${meta.nip_kepsek||'-'}</p></div></div>
    <p class="footer-note">Dokumen ini diterbitkan secara elektronik dan sah sebagai bukti kelulusan sementara sebelum ijazah asli diterbitkan.</p>
  </div>
</body></html>`;
  }
  </script>
</BaseLayout>
