{
  "name": "pengumuman-kelulusan",
  "type": "module",
  "version": "1.0.0",
  "scripts": {
    "dev": "astro dev",
    "dev:php": "php -S localhost:8090 -t public",
    "dev:all": "start /B php -S localhost:8090 -t public && astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "astro": "astro",
    "migrate": "node scripts/migrate.js",
    "migrate:lembaga": "node scripts/migrate-multi-lembaga.cjs",
    "seed": "node scripts/seed.js",
    "export-data": "node scripts/export-data.js",
    "export-users": "node scripts/export-users.js",
    "db:setup": "node scripts/migrate.js && node scripts/seed.js && node scripts/export-data.js && node scripts/export-users.js",
    "generate-pdf": "node scripts/generate-pdf.js",
    "publish": "node scripts/export-data.js && node scripts/export-users.js && node scripts/generate-pdf.js && astro build",
    "deploy": "node scripts/deploy.js"
  },
  "dependencies": {
    "@astrojs/tailwind": "^5.1.0",
    "astro": "^6.1.10",
    "tailwindcss": "^3.4.0",
    "xlsx-js-style": "^1.2.0"
  },
  "devDependencies": {
    "adm-zip": "^0.5.17",
    "mysql2": "^3.11.0",
    "puppeteer": "^24.42.0",
    "typescript": "^5.4.0"
  }
