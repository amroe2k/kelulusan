# ──────────────────────────────────────────────────
#  Kelulusan Portal — Environment Template
#  Salin file ini menjadi .env lalu sesuaikan nilainya
#  cp .env.example .env
# ──────────────────────────────────────────────────

# ─── Database MySQL ────────────────────────────────
DB_HOST=localhost
DB_PORT=3306
DB_NAME=db_kelulusan
DB_USER=root
DB_PASS=
DB_CHARSET=utf8mb4

# ─── Aplikasi ──────────────────────────────────────
APP_ENV=local
APP_URL=http://localhost:3000

# ─── Session ───────────────────────────────────────
SESSION_NAME=kls_session

# ─── JSON Retention ────────────────────────────────
# Jumlah maksimal arsip JSON yang disimpan per lembaga (min: 1, recommended: 5-10)
JSON_RETENTION_LIMIT=5
